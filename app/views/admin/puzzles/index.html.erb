<style>
.admin-page { overflow-y: auto; height: 100%; box-sizing: border-box; padding: 0; }
.admin-sticky-hdr { position: sticky; top: 0; z-index: 10; background: linear-gradient(135deg, #ede8fb 0%, #fae3d5 100%); padding: 20px 24px 16px; border-bottom: 1px solid rgba(0,0,0,0.06); }
.admin-inner { max-width: 960px; margin: 0 auto; padding: 24px 24px 48px; }
.admin-hdr { display: flex; align-items: center; justify-content: space-between; }
.admin-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #aaa; margin: 0 0 4px; font-family: 'Inter', system-ui, sans-serif; }
.admin-title { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: #1a1a2e; margin: 0; }
.btn-new { background: #5B53D6; color: white; padding: 10px 18px; border-radius: 12px; font-size: 13px; font-weight: 700; text-decoration: none; font-family: 'Inter', system-ui, sans-serif; white-space: nowrap; }
.section-lbl { font-size: 14px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #666; margin: 0 0 12px; font-family: 'Inter', system-ui, sans-serif; }
.admin-card { background: white; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 32px; overflow: clip; }
.tbl-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
.admin-tbl { width: 100%; border-collapse: collapse; font-family: 'Inter', system-ui, sans-serif; min-width: 560px; }
.admin-tbl thead th {
  padding: 10px 14px; text-align: left; font-weight: 600; color: #888; font-size: 11px;
  text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap;
  background: white; position: sticky; top: 0; z-index: 1;
  border-bottom: 1px solid #f0f0f0;
}
.admin-tbl td { padding: 10px 14px; font-size: 13px; color: #1a1a2e; vertical-align: middle; border-bottom: 1px solid #f8f8f8; }
.admin-tbl tr:last-child td { border-bottom: none; }
.c-id { width: 55px; color: #aaa; }
.c-title { width: 200px; max-width: 200px; }
.c-title-inner { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200px; font-weight: 500; display: block; }
.c-type { width: 65px; }
.c-date { white-space: nowrap; }
.c-pub { width: 95px; }
.c-actions { width: 170px; white-space: nowrap; }
.c-actions-inner { display: flex; gap: 12px; align-items: center; }

.bdg { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; }
.bdg-pub { background: #e8f5ec; color: #1a6636; }
.bdg-draft { background: #f4f4f4; color: #888; }
.bdg-today { margin-left: 6px; font-size: 10px; font-weight: 700; background: #2BAB65; color: white; padding: 2px 7px; border-radius: 999px; vertical-align: middle; }
.bdg-daily { background: #ede9fe; color: #5B53D6; }
.bdg-user { background: #fff7ed; color: #c05621; }

.btn-view { color: #888; font-weight: 600; text-decoration: none; font-size: 13px; font-family: 'Inter', system-ui, sans-serif; }
.btn-edit { color: #5B53D6; font-weight: 600; text-decoration: none; font-size: 13px; font-family: 'Inter', system-ui, sans-serif; }
.btn-del { color: #e53e3e; background: transparent; border: none; cursor: pointer; font-size: 13px; font-family: 'Inter', system-ui, sans-serif; padding: 0; font-weight: 600; }

.empty-state { padding: 32px; text-align: center; color: #aaa; font-size: 14px; font-family: 'Inter', system-ui, sans-serif; }
.empty-link { color: #5B53D6; font-weight: 600; text-decoration: none; }

/* Mobile: hide table, show cards */
.puzzle-cards { display: none; }
@media (max-width: 640px) {
  .tbl-scroll { display: none; }
  .puzzle-cards { display: block; }
  .admin-sticky-hdr { padding: 14px 16px 12px; }
  .admin-hdr { flex-direction: column; align-items: flex-start; gap: 10px; }
  .admin-inner { padding: 16px 16px 48px; }
}
.pcard { padding: 14px 16px; border-bottom: 1px solid #f0f0f0; font-family: 'Inter', system-ui, sans-serif; }
.pcard:last-child { border-bottom: none; }
.pcard-id { font-size: 11px; color: #aaa; margin-bottom: 3px; }
.pcard-title { font-size: 14px; font-weight: 600; color: #1a1a2e; margin-bottom: 6px; word-break: break-word; }
.pcard-meta { font-size: 12px; color: #888; margin-bottom: 10px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
.pcard-actions { display: flex; gap: 12px; align-items: center; }
</style>

<div class="admin-page">

  <div class="admin-sticky-hdr">
    <div style="max-width:960px;margin:0 auto;">
      <div class="admin-hdr">
        <div>
          <p class="admin-eyebrow">Admin</p>
          <h1 class="admin-title">Puzzle Scheduler</h1>
        </div>
        <a href="/admin/puzzles/new" class="btn-new">+ New puzzle</a>
      </div>
    </div>
  </div>

  <div class="admin-inner">

    <%# ── SCHEDULED ─────────────────────────────────────────── %>
    <h2 class="section-lbl">Scheduled</h2>
    <div class="admin-card">
      <% if @scheduled.any? %>
        <% today = Date.today %>

        <%# Desktop table %>
        <div class="tbl-scroll">
          <table class="admin-tbl">
            <thead>
              <tr>
                <th class="c-id">ID</th>
                <th class="c-title">Title</th>
                <th class="c-type">Type</th>
                <th class="c-date">Date</th>
                <th class="c-pub">Published</th>
                <th class="c-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @scheduled.each do |puzzle| %>
                <%
                  is_today   = puzzle.scheduled_date == today
                  is_past    = puzzle.scheduled_date < today
                  date_color = is_today ? "#2BAB65" : (is_past ? "#aaa" : "#1a1a2e")
                  row_bg     = is_today ? "background:#f0fdf4;" : ""
                %>
                <tr style="<%= row_bg %>">
                  <td class="c-id">#<%= puzzle.id %></td>
                  <td class="c-title">
                    <span class="c-title-inner" title="<%= puzzle.title %>"><%= puzzle.title.presence || "—" %></span>
                  </td>
                  <td class="c-type"><span class="bdg bdg-daily">Daily</span></td>
                  <td class="c-date" style="color:<%= date_color %>;font-weight:<%= is_today ? '700' : '400' %>;">
                    <%= puzzle.scheduled_date.strftime("%a %-d %b %Y") %>
                    <% if is_today %><span class="bdg-today">TODAY</span><% end %>
                  </td>
                  <td class="c-pub">
                    <span class="bdg <%= puzzle.published? ? 'bdg-pub' : 'bdg-draft' %>">
                      <%= puzzle.published? ? "Published" : "Draft" %>
                    </span>
                  </td>
                  <td class="c-actions">
                    <div class="c-actions-inner">
                      <a href="/admin/puzzles/<%= puzzle.id %>/edit" class="btn-edit">Edit</a>
                      <%= button_to "Delete", admin_puzzle_path(puzzle), method: :delete,
                            data: { turbo_confirm: "Are you sure you want to delete this puzzle? This cannot be undone." },
                            form: { style: "display:contents;" },
                            class: "btn-del" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Mobile cards %>
        <div class="puzzle-cards">
          <% @scheduled.each do |puzzle| %>
            <%
              is_today = puzzle.scheduled_date == today
              is_past  = puzzle.scheduled_date < today
            %>
            <div class="pcard" style="<%= is_today ? 'background:#f0fdf4;' : '' %>">
              <div class="pcard-id">#<%= puzzle.id %></div>
              <div class="pcard-title"><%= puzzle.title.presence || "—" %></div>
              <div class="pcard-meta">
                <span class="bdg bdg-daily">Daily</span>
                <span><%= puzzle.scheduled_date.strftime("%-d %b %Y") %></span>
                <% if is_today %><span class="bdg-today">TODAY</span><% end %>
                <span class="bdg <%= puzzle.published? ? 'bdg-pub' : 'bdg-draft' %>">
                  <%= puzzle.published? ? "Published" : "Draft" %>
                </span>
              </div>
              <div class="pcard-actions">
                <a href="/admin/puzzles/<%= puzzle.id %>/edit" class="btn-edit">Edit</a>
                <%= button_to "Delete", admin_puzzle_path(puzzle), method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this puzzle? This cannot be undone." },
                      form: { style: "display:contents;" },
                      class: "btn-del" %>
              </div>
            </div>
          <% end %>
        </div>

      <% else %>
        <div class="empty-state">
          No scheduled puzzles yet. <a href="/admin/puzzles/new" class="empty-link">Schedule one now.</a>
        </div>
      <% end %>
    </div>

    <%# ── COMMUNITY ─────────────────────────────────────────── %>
    <h2 class="section-lbl">Community created</h2>
    <div class="admin-card">
      <% if @community.any? %>

        <%# Desktop table %>
        <div class="tbl-scroll">
          <table class="admin-tbl">
            <thead>
              <tr>
                <th class="c-id">ID</th>
                <th class="c-title">Title</th>
                <th class="c-type">Type</th>
                <th class="c-date">Created</th>
                <th class="c-pub">Published</th>
                <th class="c-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @community.each do |puzzle| %>
                <tr>
                  <td class="c-id">#<%= puzzle.id %></td>
                  <td class="c-title">
                    <span class="c-title-inner" title="<%= puzzle.title %>"><%= puzzle.title.presence || "—" %></span>
                  </td>
                  <td class="c-type"><span class="bdg bdg-user">User</span></td>
                  <td class="c-date" style="color:#aaa;"><%= puzzle.created_at.strftime("%-d %b %Y") %></td>
                  <td class="c-pub">
                    <span class="bdg <%= puzzle.published? ? 'bdg-pub' : 'bdg-draft' %>">
                      <%= puzzle.published? ? "Published" : "Draft" %>
                    </span>
                  </td>
                  <td class="c-actions">
                    <div class="c-actions-inner">
                      <a href="/puzzles/<%= puzzle.id %>" target="_blank" class="btn-view">View</a>
                      <a href="/admin/puzzles/<%= puzzle.id %>/edit" class="btn-edit">Edit</a>
                      <%= button_to "Delete", admin_puzzle_path(puzzle), method: :delete,
                            data: { turbo_confirm: "Are you sure you want to delete this puzzle? This cannot be undone." },
                            form: { style: "display:contents;" },
                            class: "btn-del" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Mobile cards %>
        <div class="puzzle-cards">
          <% @community.each do |puzzle| %>
            <div class="pcard">
              <div class="pcard-id">#<%= puzzle.id %></div>
              <div class="pcard-title"><%= puzzle.title.presence || "—" %></div>
              <div class="pcard-meta">
                <span class="bdg bdg-user">User</span>
                <span><%= puzzle.created_at.strftime("%-d %b %Y") %></span>
                <span class="bdg <%= puzzle.published? ? 'bdg-pub' : 'bdg-draft' %>">
                  <%= puzzle.published? ? "Published" : "Draft" %>
                </span>
              </div>
              <div class="pcard-actions">
                <a href="/puzzles/<%= puzzle.id %>" target="_blank" class="btn-view">View</a>
                <a href="/admin/puzzles/<%= puzzle.id %>/edit" class="btn-edit">Edit</a>
                <%= button_to "Delete", admin_puzzle_path(puzzle), method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this puzzle? This cannot be undone." },
                      form: { style: "display:contents;" },
                      class: "btn-del" %>
              </div>
            </div>
          <% end %>
        </div>

      <% else %>
        <div class="empty-state">No community puzzles yet.</div>
      <% end %>
    </div>

    <%# ── ADMIN CREATED ─────────────────────────────────────────── %>
    <h2 class="section-lbl">Admin created</h2>
    <div class="admin-card">
      <% if @admin_created.any? %>

        <%# Desktop table %>
        <div class="tbl-scroll">
          <table class="admin-tbl">
            <thead>
              <tr>
                <th class="c-id">ID</th>
                <th class="c-title">Title</th>
                <th class="c-date">Created</th>
                <th class="c-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @admin_created.each do |puzzle| %>
                <tr>
                  <td class="c-id">#<%= puzzle.id %></td>
                  <td class="c-title">
                    <span class="c-title-inner" title="<%= puzzle.title %>"><%= puzzle.title.presence || "—" %></span>
                  </td>
                  <td class="c-date" style="color:#aaa;"><%= puzzle.created_at.strftime("%-d %b %Y") %></td>
                  <td class="c-actions">
                    <div class="c-actions-inner">
                      <a href="/puzzles/<%= puzzle.id %>" target="_blank" class="btn-view">View</a>
                      <a href="/admin/puzzles/<%= puzzle.id %>/edit" class="btn-edit">Edit</a>
                      <%= button_to "Delete", admin_puzzle_path(puzzle), method: :delete,
                            data: { turbo_confirm: "Are you sure you want to delete this puzzle? This cannot be undone." },
                            form: { style: "display:contents;" },
                            class: "btn-del" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <%# Mobile cards %>
        <div class="puzzle-cards">
          <% @admin_created.each do |puzzle| %>
            <div class="pcard">
              <div class="pcard-id">#<%= puzzle.id %></div>
              <div class="pcard-title"><%= puzzle.title.presence || "—" %></div>
              <div class="pcard-meta">
                <span><%= puzzle.created_at.strftime("%-d %b %Y") %></span>
              </div>
              <div class="pcard-actions">
                <a href="/puzzles/<%= puzzle.id %>" target="_blank" class="btn-view">View</a>
                <a href="/admin/puzzles/<%= puzzle.id %>/edit" class="btn-edit">Edit</a>
                <%= button_to "Delete", admin_puzzle_path(puzzle), method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete this puzzle? This cannot be undone." },
                      form: { style: "display:contents;" },
                      class: "btn-del" %>
              </div>
            </div>
          <% end %>
        </div>

      <% else %>
        <div class="empty-state">
          No admin puzzles yet. <a href="/admin/puzzles/new" class="empty-link">Create one now.</a>
        </div>
      <% end %>
    </div>

  </div>
</div>
