<%= form_with model: [:admin, puzzle], id: "admin-puzzle-form",
      style: "display:flex;flex-direction:column;gap:12px;font-family:'Inter',system-ui,sans-serif;" do |f| %>

  <% if puzzle.errors.any? %>
    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 14px;">
      <ul style="margin:0;padding:0 0 0 16px;font-size:13px;color:#991b1b;">
        <% puzzle.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title + Date in one row %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;align-items:end;">
    <div>
      <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:4px;">Title <span style="font-weight:400;text-transform:none;">(optional)</span></label>
      <%= f.text_field :title, placeholder: "Leave blank to auto-generate",
            style: "width:100%;box-sizing:border-box;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;padding:7px 12px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
    </div>
    <div>
      <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:4px;">Schedule for date <span style="font-weight:400;text-transform:none;">(optional — leave blank to save to library)</span></label>
      <%= f.date_field :scheduled_date,
            style: "width:100%;box-sizing:border-box;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;padding:7px 12px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
    </div>
  </div>

  <%# SVG Venn editor %>
  <div>
    <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:6px;">Word regions</label>
    <div style="border:1.5px solid rgba(0,0,0,0.08);border-radius:14px;overflow:hidden;background:linear-gradient(135deg,#ede8fb 0%,#fae3d5 100%);padding:4px;">
      <svg viewBox="0 0 560 460" style="width:100%;height:auto;display:block;max-height:340px;" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">

        <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.45" stroke="#5B53D6" stroke-width="2"/>
        <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.45" stroke="#2BAB65" stroke-width="2"/>
        <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.45" stroke="#E8631A" stroke-width="2"/>

        <rect x="242" y="8" width="76" height="28" rx="14" fill="#5B53D6"/>
        <text x="280" y="27" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em">CIRCLE A</text>

        <rect x="147" y="399" width="76" height="28" rx="14" fill="#2BAB65"/>
        <text x="185" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em">CIRCLE B</text>

        <rect x="337" y="399" width="76" height="28" rx="14" fill="#E8631A"/>
        <text x="375" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em">CIRCLE C</text>

        <foreignObject x="200" y="52" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_a][]"
            value="<%= puzzle.words_a&.join(', ') %>" placeholder="only in A..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #5B53D6;border-radius:999px;padding:0 10px;text-align:center;background:#EDEAFC;outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#1a1a2e;"/>
        </foreignObject>

        <foreignObject x="28" y="308" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_b][]"
            value="<%= puzzle.words_b&.join(', ') %>" placeholder="only in B..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #2BAB65;border-radius:999px;padding:0 10px;text-align:center;background:#E5F5EC;outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#1a1a2e;"/>
        </foreignObject>

        <foreignObject x="372" y="308" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_c][]"
            value="<%= puzzle.words_c&.join(', ') %>" placeholder="only in C..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #E8631A;border-radius:999px;padding:0 10px;text-align:center;background:#FDF0E9;outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#1a1a2e;"/>
        </foreignObject>

        <foreignObject x="118" y="200" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_ab][]"
            value="<%= puzzle.words_ab&.join(', ') %>" placeholder="in A &amp; B..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #bbb;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.9);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#333;"/>
        </foreignObject>

        <foreignObject x="282" y="200" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_ac][]"
            value="<%= puzzle.words_ac&.join(', ') %>" placeholder="in A &amp; C..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #bbb;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.9);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#333;"/>
        </foreignObject>

        <foreignObject x="200" y="322" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_bc][]"
            value="<%= puzzle.words_bc&.join(', ') %>" placeholder="in B &amp; C..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #bbb;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.9);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#333;"/>
        </foreignObject>

        <foreignObject x="200" y="234" width="160" height="36">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_abc][]"
            value="<%= puzzle.words_abc&.join(', ') %>" placeholder="all three..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #888;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.95);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#111;font-weight:600;"/>
        </foreignObject>

      </svg>
    </div>
  </div>

  <%# Secret labels %>
  <div>
    <label style="display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:6px;">Secret labels — the answers</label>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
      <div>
        <%= f.text_field :label_a, placeholder: "A answer…",
              style: "width:100%;box-sizing:border-box;border:1.5px solid #5B53D6;border-radius:10px;padding:7px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:#EDEAFC;" %>
      </div>
      <div>
        <%= f.text_field :label_b, placeholder: "B answer…",
              style: "width:100%;box-sizing:border-box;border:1.5px solid #2BAB65;border-radius:10px;padding:7px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:#E5F5EC;" %>
      </div>
      <div>
        <%= f.text_field :label_c, placeholder: "C answer…",
              style: "width:100%;box-sizing:border-box;border:1.5px solid #E8631A;border-radius:10px;padding:7px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:#FDF0E9;" %>
      </div>
    </div>
  </div>

  <%= f.submit puzzle.persisted? ? "Save changes" : "Save puzzle",
        style: "background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;height:44px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;width:100%;margin-top:8px;" %>

<% end %>

<script>
  // Auto-fill title from centre word (words_abc), unless user has manually set a title
  (function() {
    var titleInput = document.getElementById('puzzle_title');
    var abcInput   = document.querySelector('[name="puzzle[words_abc][]"]');
    if (!titleInput || !abcInput) return;

    var autoFill = titleInput.value === '';

    titleInput.addEventListener('input', function() {
      autoFill = titleInput.value === '';
    });

    abcInput.addEventListener('input', function() {
      if (!autoFill) return;
      var first = abcInput.value.split(',')[0].trim();
      titleInput.value = first;
    });
  })();

  document.getElementById('admin-puzzle-form').addEventListener('submit', function() {
    ['puzzle[words_a][]','puzzle[words_b][]','puzzle[words_c][]',
     'puzzle[words_ab][]','puzzle[words_ac][]','puzzle[words_bc][]','puzzle[words_abc][]'].forEach(function(name) {
      var el = document.querySelector('[name="' + name + '"]');
      if (el) el.value = el.value.split(',').map(function(s){ return s.trim(); }).filter(Boolean).join(',');
    });
  });
</script>
