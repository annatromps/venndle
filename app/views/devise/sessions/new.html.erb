<div style="height:100%;display:flex;align-items:center;justify-content:center;padding:20px;box-sizing:border-box;">
  <div style="background:white;border-radius:20px;box-shadow:0 4px 24px rgba(0,0,0,0.08);padding:32px 28px;width:100%;max-width:360px;">
    <h2 style="font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#1a1a2e;margin:0 0 20px;">Sign in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label style="display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:5px;font-family:'Inter',system-ui,sans-serif;">Email or username</label>
          <%= f.text_field :email, autofocus: true, autocomplete: "username",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
        </div>

        <div>
          <%= f.label :password, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:5px;font-family:'Inter',system-ui,sans-serif;" %>
          <%= f.password_field :password, autocomplete: "current-password",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div style="display:flex;align-items:center;gap:8px;">
            <%= f.check_box :remember_me, checked: true %>
            <%= f.label :remember_me, style: "font-size:13px;color:#666;font-family:'Inter',system-ui,sans-serif;" %>
          </div>
        <% end %>

        <%= f.submit "Sign in",
              style: "width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;padding:12px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;" %>
      </div>
    <% end %>

    <% if devise_mapping.recoverable? %>
      <div style="margin-top:12px;text-align:center;">
        <%= link_to "Forgot your password?", new_password_path(resource_name),
              style: "font-size:12px;color:#aaa;text-decoration:none;font-family:'Inter',system-ui,sans-serif;" %>
      </div>
    <% end %>

    <div style="margin-top:20px;border-top:1px solid #f0f0f0;padding-top:20px;">
      <p style="font-size:13px;font-weight:600;color:#888;margin:0 0 10px;text-align:center;font-family:'Inter',system-ui,sans-serif;">New here?</p>
      <a href="<%= new_registration_path(resource_name) %>"
         style="display:block;width:100%;box-sizing:border-box;text-align:center;background:#f4f4f5;color:#1a1a2e;font-weight:700;font-size:14px;text-decoration:none;border-radius:12px;padding:12px;font-family:'Inter',system-ui,sans-serif;">
        Create an account
      </a>
    </div>
  </div>
</div>
