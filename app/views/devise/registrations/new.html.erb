<div style="height:100%;overflow-y:auto;-webkit-overflow-scrolling:touch;display:flex;align-items:center;justify-content:center;padding:20px;box-sizing:border-box;">
  <div style="background:white;border-radius:20px;box-shadow:0 4px 24px rgba(0,0,0,0.08);padding:32px 28px;width:100%;max-width:360px;">
    <h2 style="font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#1a1a2e;margin:0 0 20px;">Sign up</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <div style="display:flex;align-items:baseline;gap:4px;margin-bottom:5px;">
            <%= f.label :username, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;font-family:'Inter',system-ui,sans-serif;" %>
            <span style="font-size:11px;font-weight:700;color:#e53e3e;font-family:'Inter',system-ui,sans-serif;">*</span>
          </div>
          <%= f.text_field :username, autofocus: true, autocomplete: "username",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
        </div>

        <div>
          <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:5px;">
            <%= f.label :email, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;font-family:'Inter',system-ui,sans-serif;" %>
            <span style="font-size:11px;color:#aaa;font-family:'Inter',system-ui,sans-serif;">optional</span>
          </div>
          <%= f.email_field :email, autocomplete: "email", placeholder: "For password recovery only",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
          <p style="font-size:11px;color:#bbb;margin:4px 0 0;font-family:'Inter',system-ui,sans-serif;">Leave blank to sign up with username and password only</p>
        </div>

        <div>
          <div style="display:flex;align-items:baseline;gap:4px;margin-bottom:5px;">
            <%= f.label :password, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;font-family:'Inter',system-ui,sans-serif;" %>
            <span style="font-size:11px;font-weight:700;color:#e53e3e;font-family:'Inter',system-ui,sans-serif;">*</span>
          </div>
          <% if @minimum_password_length %>
            <p style="font-size:11px;color:#aaa;margin:0 0 5px;font-family:'Inter',system-ui,sans-serif;"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <div style="position:relative;">
            <%= f.password_field :password, autocomplete: "new-password", id: "signup_password",
                  style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 40px 9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
            <button type="button" onclick="togglePw('signup_password','eye-pw')" tabindex="-1"
                    style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:#aaa;display:flex;align-items:center;">
              <svg id="eye-pw" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div>
          <div style="display:flex;align-items:baseline;gap:4px;margin-bottom:5px;">
            <%= f.label :password_confirmation, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;font-family:'Inter',system-ui,sans-serif;" %>
            <span style="font-size:11px;font-weight:700;color:#e53e3e;font-family:'Inter',system-ui,sans-serif;">*</span>
          </div>
          <div style="position:relative;">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", id: "signup_password_confirmation",
                  style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 40px 9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
            <button type="button" onclick="togglePw('signup_password_confirmation','eye-pwc')" tabindex="-1"
                    style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:#aaa;display:flex;align-items:center;">
              <svg id="eye-pwc" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <%= f.submit "Sign up",
              style: "width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;padding:12px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;margin-top:4px;" %>
      </div>
    <% end %>

    <div style="margin-top:16px;font-size:13px;color:#888;font-family:'Inter',system-ui,sans-serif;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

<script>
  function togglePw(fieldId, eyeId) {
    var field = document.getElementById(fieldId);
    var eye   = document.getElementById(eyeId);
    if (!field || !eye) return;
    var showing = field.type === 'text';
    field.type = showing ? 'password' : 'text';
    eye.innerHTML = showing
      ? '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>'
      : '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>' +
        '<path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>' +
        '<line x1="1" y1="1" x2="23" y2="23"/>';
  }
</script>
