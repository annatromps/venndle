<div style="height:100%;overflow-y:auto;-webkit-overflow-scrolling:touch;display:flex;align-items:center;justify-content:center;padding:20px;box-sizing:border-box;">
  <div style="background:white;border-radius:20px;box-shadow:0 4px 24px rgba(0,0,0,0.08);padding:32px 28px;width:100%;max-width:360px;">
    <h2 style="font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#1a1a2e;margin:0 0 20px;">Sign up</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <%= f.label :username, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:5px;font-family:'Inter',system-ui,sans-serif;" %>
          <%= f.text_field :username, autofocus: true, autocomplete: "username",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
        </div>

        <div>
          <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:5px;">
            <%= f.label :email, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;font-family:'Inter',system-ui,sans-serif;" %>
            <span style="font-size:11px;color:#aaa;font-family:'Inter',system-ui,sans-serif;">optional</span>
          </div>
          <%= f.email_field :email, autocomplete: "email", placeholder: "For password recovery only",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
          <p style="font-size:11px;color:#bbb;margin:4px 0 0;font-family:'Inter',system-ui,sans-serif;">Leave blank to sign up with username and password only</p>
        </div>

        <div>
          <%= f.label :password, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:5px;font-family:'Inter',system-ui,sans-serif;" %>
          <% if @minimum_password_length %>
            <p style="font-size:11px;color:#aaa;margin:0 0 5px;font-family:'Inter',system-ui,sans-serif;"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
        </div>

        <div>
          <%= f.label :password_confirmation, style: "display:block;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#888;margin-bottom:5px;font-family:'Inter',system-ui,sans-serif;" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                style: "width:100%;box-sizing:border-box;border:1.5px solid #e5e5e5;border-radius:10px;padding:9px 12px;font-size:14px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;" %>
        </div>

        <%= f.submit "Sign up",
              style: "width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;padding:12px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;margin-top:4px;" %>
      </div>
    <% end %>

    <div style="margin-top:16px;font-size:13px;color:#888;font-family:'Inter',system-ui,sans-serif;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
