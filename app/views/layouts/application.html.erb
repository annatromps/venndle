<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Venndle" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="min-height:100dvh;background:linear-gradient(135deg,#ede8fb 0%,#fae3d5 100%);font-family:'Inter',system-ui,sans-serif;margin:0;padding:0;">

    <%# Minimal transparent navbar %>
    <nav style="position:relative;background:transparent;padding:0 24px;">
      <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:18px 0;">

        <%# Logo %>
        <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px;">
          <svg width="28" height="28" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="38" r="28" fill="#C8C4F2" fill-opacity="0.85" stroke="#5B53D6" stroke-width="2.5"/>
            <circle cx="34" cy="65" r="28" fill="#B8E4C8" fill-opacity="0.85" stroke="#2BAB65" stroke-width="2.5"/>
            <circle cx="66" cy="65" r="28" fill="#F5C4A0" fill-opacity="0.85" stroke="#E8631A" stroke-width="2.5"/>
          </svg>
          <span style="font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:#1a1a2e;letter-spacing:-0.02em;line-height:1">Venndle</span>
        </a>

        <%# Auth links %>
        <div style="display:flex;align-items:center;gap:20px;">
          <% if user_signed_in? %>
            <span style="font-size:13px;color:#888;font-weight:500;"><%= current_user.username %></span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                  style: "font-size:13px;font-weight:600;color:#555;background:transparent;border:none;cursor:pointer;font-family:'Inter',system-ui,sans-serif;" %>
          <% else %>
            <a href="/users/sign_in" style="font-size:13px;font-weight:600;color:#555;text-decoration:none;">Sign in</a>
            <a href="/users/sign_up" style="font-size:13px;font-weight:700;color:#1a1a2e;text-decoration:none;background:white;border-radius:8px;padding:6px 14px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">Sign up</a>
          <% end %>
        </div>
      </div>
    </nav>

    <%# Flash messages %>
    <% if notice %>
      <div style="max-width:420px;margin:0 auto 0;padding:0 16px;">
        <div style="display:flex;align-items:center;gap:8px;background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;padding:10px 14px;border-radius:12px;font-size:13px;font-weight:500;">
          <span>✓</span> <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div style="max-width:420px;margin:0 auto 0;padding:0 16px;">
        <div style="display:flex;align-items:center;gap:8px;background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:10px 14px;border-radius:12px;font-size:13px;font-weight:500;">
          <span>!</span> <%= alert %>
        </div>
      </div>
    <% end %>

    <main><%= yield %></main>

  </body>
</html>
