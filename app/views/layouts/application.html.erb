<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Venndle" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white min-h-screen">
    <nav class="bg-white border-b border-gray-100 px-6 py-4">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-gray-900 tracking-tight">Venndle</a>
        <div class="flex items-center gap-6">
          <a href="/daily" class="text-sm font-medium text-gray-600 hover:text-gray-900">Daily</a>
          <a href="/puzzles" class="text-sm font-medium text-gray-600 hover:text-gray-900">Puzzles</a>
          <% if user_signed_in? %>
            <a href="/puzzles/new" class="text-sm font-medium text-gray-600 hover:text-gray-900">Create</a>
            <div class="flex items-center gap-3">
              <span class="text-sm text-gray-500"><%= current_user.username %></span>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                    class: "text-sm text-gray-500 hover:text-gray-900 bg-transparent border-none cursor-pointer" %>
            </div>
          <% else %>
            <a href="/users/sign_in" class="text-sm font-medium text-gray-600 hover:text-gray-900">Sign in</a>
            <a href="/users/sign_up" class="text-sm bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-700">Sign up</a>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-4xl mx-auto mt-4 px-6">
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm"><%= notice %></div>
      </div>
    <% end %>
    <% if alert %>
      <div class="max-w-4xl mx-auto mt-4 px-6">
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm"><%= alert %></div>
      </div>
    <% end %>

    <main class="max-w-4xl mx-auto px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
