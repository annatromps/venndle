    <script>
      function showInstructions() {
        document.getElementById('instructions-modal').style.display = 'flex';
      }
      function hideInstructions() {
        localStorage.setItem('venndle_seen_instructions', '1');
        document.getElementById('instructions-modal').style.display = 'none';
      }
      document.addEventListener('DOMContentLoaded', function() {
        if (!localStorage.getItem('venndle_seen_instructions')) {
          showInstructions();
        }
      });
    </script>

    <script>
      // ── PWA: Service Worker registration ──────────────────────────────────
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('<%= pwa_service_worker_path %>').catch(function() {});
      }

      // ── PWA: Install prompt ───────────────────────────────────────────────
      // localStorage keys:
      //   venndle_install_first_visit  — Unix ms timestamp of first ever page load (written once)
      //   venndle_install_visits       — running count of page loads, incremented each DOMContentLoaded
      //   venndle_install_snooze_until — visit count at which the banner may next appear;
      //                                  set to (visits + 5) each time the user dismisses
      //   venndle_install_done         — '1' only after browser confirms the app was installed;
      //                                  the sole permanent suppression flag
      var _deferredInstallPrompt = null;

      // Capture and hold the browser's install eligibility signal.
      window.addEventListener('beforeinstallprompt', function(e) {
        e.preventDefault();
        _deferredInstallPrompt = e;
        _maybeShowInstallBanner();
      });

      function _maybeShowInstallBanner() {
        if (!_deferredInstallPrompt) return;
        if (localStorage.getItem('venndle_install_done')) return;

        // Gate 1: must be a returning visitor from a different calendar day.
        var raw = localStorage.getItem('venndle_install_first_visit');
        if (!raw) return;
        var firstDate = new Date(parseInt(raw, 10)).toDateString();
        if (firstDate === new Date().toDateString()) return;

        // Gate 2: must not be within a snooze window.
        var visits      = parseInt(localStorage.getItem('venndle_install_visits') || '0', 10);
        var snoozeUntil = parseInt(localStorage.getItem('venndle_install_snooze_until') || '0', 10);
        if (visits < snoozeUntil) return;

        var banner = document.getElementById('install-banner');
        if (banner) banner.style.display = 'flex';
      }

      function installApp() {
        if (!_deferredInstallPrompt) return;
        _deferredInstallPrompt.prompt();
        _deferredInstallPrompt.userChoice.then(function(result) {
          _deferredInstallPrompt = null;
          var banner = document.getElementById('install-banner');
          if (banner) banner.style.display = 'none';
          if (result.outcome === 'accepted') {
            // User confirmed installation — suppress the banner permanently.
            localStorage.setItem('venndle_install_done', '1');
          } else {
            // User closed the native dialog without installing — snooze.
            _snoozeInstallBanner();
          }
        });
      }

      function dismissInstallBanner() {
        _snoozeInstallBanner();
        var banner = document.getElementById('install-banner');
        if (banner) banner.style.display = 'none';
      }

      // Record the current visit count as the snooze baseline; banner resurfaces
      // after 5 more page loads.
      function _snoozeInstallBanner() {
        var visits = parseInt(localStorage.getItem('venndle_install_visits') || '0', 10);
        localStorage.setItem('venndle_install_snooze_until', (visits + 5).toString());
      }

      // On every page load: stamp first-visit timestamp (once), increment the
      // visit counter, then attempt to show the banner in case beforeinstallprompt
      // already fired before DOMContentLoaded on fast connections.
      document.addEventListener('DOMContentLoaded', function() {
        if (!localStorage.getItem('venndle_install_first_visit')) {
          localStorage.setItem('venndle_install_first_visit', Date.now().toString());
        }
        var visits = parseInt(localStorage.getItem('venndle_install_visits') || '0', 10);
        localStorage.setItem('venndle_install_visits', (visits + 1).toString());
        _maybeShowInstallBanner();
});

  // Claude Code Fix: Handle Turbo navigation cache state
  document.addEventListener("turbo:load", function() {
    const mainModal = document.getElementById('instructions-modal');
    if (mainModal) {
      if (localStorage.getItem('venndle_seen_instructions') === '1') {
        mainModal.style.display = 'none';
      }
    }
  });

    // Target the panel directly to catch the click before event.stopPropagation() chokes it
  document.addEventListener("DOMContentLoaded", function() {
    const innerPanel = document.getElementById('instructions-panel');
    if (innerPanel) {
      innerPanel.addEventListener('click', function(event) {
        if (event.target.textContent.includes("play") || event.target.textContent.includes("Play")) {
          localStorage.setItem('venndle_seen_instructions', '1');
          document.cookie = "venndle_seen_instructions=true; path=/; max-age=31536000";
          const mainModal = document.getElementById('instructions-modal');
          if (mainModal) mainModal.style.display = 'none';
        }
      });
    }
  });

</script>
  <%= yield :body_overlays %>
  </body>
</html>
