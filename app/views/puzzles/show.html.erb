<div style="height:100%;display:flex;flex-direction:column;padding:10px 16px 8px;box-sizing:border-box;max-width:680px;margin:0 auto;width:100%;">

  <%# Header — compact %>
  <div style="flex-shrink:0;margin-bottom:6px;">
    <div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;">
      <span style="width:7px;height:7px;border-radius:50%;background:#F59E0B;display:inline-block;flex-shrink:0;"></span>
      <span style="font-size:10px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#666;font-family:'Inter',system-ui,sans-serif;">
        BY <%= @puzzle.user.username.upcase %>
      </span>
    </div>
    <h1 style="font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#1a1a2e;margin:0;line-height:1.1;">
      Puzzle &numero;<%= @puzzle.id %>
    </h1>
  </div>

  <%# Venn content — fills remaining height %>
  <div style="flex:1;min-height:0;overflow:hidden;">
    <%= render "venn", puzzle: @puzzle, game_session: @game_session, attempts: (@attempts || []) %>
  </div>
</div>
