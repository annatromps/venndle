<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Create a puzzle</h1>

  <%= form_with model: @puzzle, class: "space-y-6" do |f| %>
    <% if @puzzle.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% @puzzle.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :title, "Puzzle title", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300", placeholder: "e.g. Animals, Colours & Shapes" %>
    </div>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= f.label :label_a, "Circle A label (answer)", class: "block text-sm font-medium mb-1", style: "color:#1e3a5f" %>
        <%= f.text_field :label_a, class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2", style: "background:#f0f7ff", placeholder: "e.g. Animals" %>
      </div>
      <div>
        <%= f.label :label_b, "Circle B label (answer)", class: "block text-sm font-medium mb-1", style: "color:#2d5a0f" %>
        <%= f.text_field :label_b, class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2", style: "background:#f4fced", placeholder: "e.g. Colours" %>
      </div>
      <div>
        <%= f.label :label_c, "Circle C label (answer)", class: "block text-sm font-medium mb-1", style: "color:#78350f" %>
        <%= f.text_field :label_c, class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2", style: "background:#fffbeb", placeholder: "e.g. Round things" %>
      </div>
    </div>

    <p class="text-xs text-gray-400">Enter words for each region, comma-separated.</p>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= label_tag "puzzle_words_a", "A only words", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "puzzle[words_a][]", @puzzle.words_a&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", style: "background:#f0f7ff", placeholder: "cat, dog, bee" %>
      </div>
      <div>
        <%= label_tag "puzzle_words_b", "B only words", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "puzzle[words_b][]", @puzzle.words_b&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", style: "background:#f4fced", placeholder: "red, blue, green" %>
      </div>
      <div>
        <%= label_tag "puzzle_words_c", "C only words", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "puzzle[words_c][]", @puzzle.words_c&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", style: "background:#fffbeb", placeholder: "ball, moon, coin" %>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4">
      <div>
        <%= label_tag "puzzle_words_ab", "A ∩ B words", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "puzzle[words_ab][]", @puzzle.words_ab&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", placeholder: "ladybird, parrot" %>
      </div>
      <div>
        <%= label_tag "puzzle_words_ac", "A ∩ C words", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "puzzle[words_ac][]", @puzzle.words_ac&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", placeholder: "pufferfish, hedgehog" %>
      </div>
      <div>
        <%= label_tag "puzzle_words_bc", "B ∩ C words", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= text_field_tag "puzzle[words_bc][]", @puzzle.words_bc&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", placeholder: "orange, tomato" %>
      </div>
    </div>

    <div>
      <%= label_tag "puzzle_words_abc", "A ∩ B ∩ C words (centre)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= text_field_tag "puzzle[words_abc][]", @puzzle.words_abc&.join(", "), class: "w-full border border-gray-200 rounded-lg px-3 py-2 text-sm", placeholder: "goldfish" %>
    </div>

    <%= f.submit "Create puzzle", class: "bg-gray-900 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-gray-700 cursor-pointer" %>
  <% end %>
</div>

<script>
  // Convert comma-separated text inputs into arrays on submit
  document.querySelector('form').addEventListener('submit', function(e) {
    const arrayInputs = ['puzzle[words_a][]', 'puzzle[words_b][]', 'puzzle[words_c][]',
                         'puzzle[words_ab][]', 'puzzle[words_ac][]', 'puzzle[words_bc][]', 'puzzle[words_abc][]'];
    arrayInputs.forEach(function(name) {
      const input = document.querySelector('[name="' + name + '"]');
      if (input) {
        const words = input.value.split(',').map(s => s.trim()).filter(Boolean);
        input.value = words.join(',');
      }
    });
  });
</script>
