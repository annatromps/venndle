<%# Outer wrapper fills <main> exactly — no scroll, no overflow %>
<div style="height:100%;overflow:hidden;display:flex;flex-direction:column;box-sizing:border-box;max-width:700px;margin:0 auto;width:100%;padding:0 16px;">

  <%= form_with model: @puzzle, id: "puzzle-form", style: "display:flex;flex-direction:column;height:100%;overflow:hidden;" do |f| %>

    <%# ── TOP: title input + errors ── flex-shrink:0 so it never collapses %>
    <div style="flex-shrink:0;padding-top:10px;display:flex;flex-direction:column;gap:8px;">

      <div>
        <h1 style="font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#1a1a2e;margin:0 0 6px;line-height:1.1;">Create a Venndle</h1>
        <%= f.text_field :title,
          style: "width:100%;box-sizing:border-box;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;padding:7px 12px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:rgba(255,255,255,0.6);",
          placeholder: "Title — leave blank for auto" %>
      </div>

      <% if @puzzle.errors.any? %>
        <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:10px 12px;">
          <ul style="margin:0;padding:0 0 0 14px;font-size:12px;color:#991b1b;font-family:'Inter',system-ui,sans-serif;">
            <% @puzzle.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

    </div>

    <%# ── MIDDLE: Venn diagram — grows and shrinks to fill available space %>
    <div style="flex:1;min-height:0;overflow:hidden;">
      <svg viewBox="0 0 560 460" style="width:100%;height:100%;display:block;" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">

        <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.45" stroke="#5B53D6" stroke-width="2"/>
        <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.45" stroke="#2BAB65" stroke-width="2"/>
        <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.45" stroke="#E8631A" stroke-width="2"/>

        <rect x="242" y="8" width="76" height="28" rx="14" fill="#5B53D6"/>
        <text x="280" y="27" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em">CIRCLE A</text>

        <rect x="147" y="399" width="76" height="28" rx="14" fill="#2BAB65"/>
        <text x="185" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em">CIRCLE B</text>

        <rect x="337" y="399" width="76" height="28" rx="14" fill="#E8631A"/>
        <text x="375" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em">CIRCLE C</text>

        <foreignObject x="200" y="56" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_a][]"
            value="<%= @puzzle.words_a&.join(', ') %>" placeholder="only in A..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #5B53D6;border-radius:999px;padding:0 10px;text-align:center;background:#EDEAFC;outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#1a1a2e;"/>
        </foreignObject>

        <foreignObject x="28" y="308" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_b][]"
            value="<%= @puzzle.words_b&.join(', ') %>" placeholder="only in B..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #2BAB65;border-radius:999px;padding:0 10px;text-align:center;background:#E5F5EC;outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#1a1a2e;"/>
        </foreignObject>

        <foreignObject x="372" y="308" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_c][]"
            value="<%= @puzzle.words_c&.join(', ') %>" placeholder="only in C..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #E8631A;border-radius:999px;padding:0 10px;text-align:center;background:#FDF0E9;outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#1a1a2e;"/>
        </foreignObject>

        <foreignObject x="118" y="200" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_ab][]"
            value="<%= @puzzle.words_ab&.join(', ') %>" placeholder="in A &amp; B..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #bbb;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.9);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#333;"/>
        </foreignObject>

        <foreignObject x="282" y="200" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_ac][]"
            value="<%= @puzzle.words_ac&.join(', ') %>" placeholder="in A &amp; C..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #bbb;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.9);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#333;"/>
        </foreignObject>

        <foreignObject x="200" y="322" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_bc][]"
            value="<%= @puzzle.words_bc&.join(', ') %>" placeholder="in B &amp; C..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #bbb;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.9);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#333;"/>
        </foreignObject>

        <foreignObject x="200" y="234" width="160" height="28">
          <input xmlns="http://www.w3.org/1999/xhtml" type="text" name="puzzle[words_abc][]"
            value="<%= @puzzle.words_abc&.join(', ') %>" placeholder="all three..."
            style="width:100%;height:26px;font-size:11px;border:1.5px solid #888;border-radius:999px;padding:0 10px;text-align:center;background:rgba(255,255,255,0.95);outline:none;box-sizing:border-box;font-family:system-ui,sans-serif;color:#111;font-weight:600;"/>
        </foreignObject>

      </svg>
    </div>

    <%# ── BOTTOM: secret labels + visibility + submit — flex-shrink:0, never cut off %>
    <div style="flex-shrink:0;display:flex;flex-direction:column;gap:8px;padding-bottom:16px;">

      <div>
        <div style="font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#888;margin-bottom:6px;font-family:'Inter',system-ui,sans-serif;">Secret labels — what connects the words in each circle?</div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
          <div><%= f.text_field :label_a, style: "width:100%;box-sizing:border-box;border:1.5px solid #5B53D6;border-radius:10px;padding:7px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:#EDEAFC;", placeholder: "A answer..." %></div>
          <div><%= f.text_field :label_b, style: "width:100%;box-sizing:border-box;border:1.5px solid #2BAB65;border-radius:10px;padding:7px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:#E5F5EC;", placeholder: "B answer..." %></div>
          <div><%= f.text_field :label_c, style: "width:100%;box-sizing:border-box;border:1.5px solid #E8631A;border-radius:10px;padding:7px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;background:#FDF0E9;", placeholder: "C answer..." %></div>
        </div>
      </div>

      <%# Visibility toggle %>
      <div>
        <div style="font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#888;margin-bottom:6px;font-family:'Inter',system-ui,sans-serif;">Visibility</div>
        <div style="display:flex;gap:8px;margin-bottom:6px;">
          <button type="button" id="toggle-public" onclick="setVisibility('public')"
            style="flex:1;padding:8px 0;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'Inter',system-ui,sans-serif;border:1.5px solid #1a1a2e;background:#1a1a2e;color:white;">
            Public
          </button>
          <button type="button" id="toggle-private" onclick="setVisibility('private')"
            style="flex:1;padding:8px 0;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Inter',system-ui,sans-serif;border:1.5px solid #ddd;background:white;color:#555;">
            Private
          </button>
        </div>
        <p id="visibility-desc" style="font-size:11px;color:#aaa;margin:0;font-family:'Inter',system-ui,sans-serif;">Appears in the community list — anyone can find and play it.</p>
        <input type="hidden" name="puzzle[published]" id="published-input" value="true">
      </div>

      <%= f.submit "Create puzzle",
        style: "width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;height:44px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;" %>

    </div>

  <% end %>
</div>

<script>
  function setVisibility(mode) {
    var isPublic = mode === 'public';
    document.getElementById('published-input').value = isPublic ? 'true' : 'false';

    var pub  = document.getElementById('toggle-public');
    var priv = document.getElementById('toggle-private');
    var desc = document.getElementById('visibility-desc');

    pub.style.background  = isPublic ? '#1a1a2e' : 'white';
    pub.style.color       = isPublic ? 'white'   : '#555';
    pub.style.borderColor = isPublic ? '#1a1a2e' : '#ddd';
    pub.style.fontWeight  = isPublic ? '700'     : '600';

    priv.style.background  = isPublic ? 'white'   : '#1a1a2e';
    priv.style.color       = isPublic ? '#555'    : 'white';
    priv.style.borderColor = isPublic ? '#ddd'    : '#1a1a2e';
    priv.style.fontWeight  = isPublic ? '600'     : '700';

    desc.textContent = isPublic
      ? 'Appears in the community list — anyone can find and play it.'
      : 'Only accessible via direct link — won\'t appear in the community list.';
  }

  (function() {
    var titleInput = document.getElementById('puzzle_title');
    var abcInput   = document.querySelector('[name="puzzle[words_abc][]"]');
    if (!titleInput || !abcInput) return;
    var lastAuto = '';
    abcInput.addEventListener('input', function() {
      var first = abcInput.value.split(',')[0].trim();
      if (titleInput.value === '' || titleInput.value === lastAuto) {
        titleInput.value = first;
        lastAuto = first;
      }
    });
  })();

  document.getElementById('puzzle-form').addEventListener('submit', function() {
    ['puzzle[words_a][]','puzzle[words_b][]','puzzle[words_c][]',
     'puzzle[words_ab][]','puzzle[words_ac][]','puzzle[words_bc][]','puzzle[words_abc][]'].forEach(function(name) {
      const el = document.querySelector('[name="' + name + '"]');
      if (el) el.value = el.value.split(',').map(function(s){ return s.trim(); }).filter(Boolean).join(',');
    });
  });
</script>
