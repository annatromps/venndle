<div style="height:100%;display:flex;flex-direction:column;padding:10px 16px 8px;box-sizing:border-box;max-width:700px;margin:0 auto;width:100%;">

  <%# Header %>
  <div style="flex-shrink:0;margin-bottom:6px;">
    <div style="margin-bottom:4px;">
      <span style="display:inline-flex;align-items:center;background:#888;color:white;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:999px;font-family:'Inter',system-ui,sans-serif;">Practice</span>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
      <div>
        <h1 style="font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#1a1a2e;margin:0;line-height:1.15;">Bed linen</h1>
        <p style="font-size:12px;color:#aaa;margin:2px 0 0;font-family:'Inter',system-ui,sans-serif;">Try the game — no account needed</p>
      </div>
      <a href="/" style="flex-shrink:0;font-size:12px;font-weight:600;color:#5B53D6;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">Play today →</a>
    </div>
  </div>

  <%# Venn content — fills remaining height %>
  <div style="flex:1;min-height:0;overflow:hidden;">
    <%= render "venn", puzzle: @puzzle, game_session: @game_session, attempts: (@attempts || []) %>
  </div>

</div>
