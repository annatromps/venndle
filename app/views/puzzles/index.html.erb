<div style="height:100%;overflow-y:auto;-webkit-overflow-scrolling:touch;box-sizing:border-box;">
  <div style="max-width:760px;margin:0 auto;padding:20px 20px 40px;">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:24px;">
      <div>
        <p style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#aaa;margin:0 0 4px;font-family:'Inter',system-ui,sans-serif;">Community</p>
        <h1 style="font-family:'Playfair Display',serif;font-size:40px;font-weight:700;color:#1a1a2e;margin:0;letter-spacing:-0.03em;line-height:1;">Puzzles</h1>
      </div>
      <% if user_signed_in? %>
        <a href="/puzzles/new" style="display:inline-flex;align-items:center;gap:6px;font-weight:700;font-size:13px;padding:10px 18px;border-radius:12px;background:#1a1a2e;color:white;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">
          <span style="font-size:1.1em;">+</span> Create puzzle
        </a>
      <% end %>
    </div>

    <% if @puzzles.any? %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px;">
        <% @puzzles.each do |puzzle| %>
          <a href="/puzzles/<%= puzzle.id %>" style="display:block;background:white;border-radius:18px;padding:18px 16px;border:2px solid transparent;box-shadow:0 2px 12px rgba(0,0,0,0.07);text-decoration:none;transition:box-shadow 0.15s;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;">
              <div>
                <p style="font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#aaa;margin:0 0 4px;font-family:'Inter',system-ui,sans-serif;">by <%= puzzle.user.username %></p>
                <p style="font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:#1a1a2e;margin:0;line-height:1.2;">Puzzle #<%= puzzle.id %></p>
              </div>
              <svg width="32" height="32" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;margin-left:8px;opacity:0.8;">
                <circle cx="50" cy="38" r="28" fill="#C8C4F2" fill-opacity="0.8" stroke="#5B53D6" stroke-width="2"/>
                <circle cx="34" cy="65" r="28" fill="#B8E4C8" fill-opacity="0.8" stroke="#2BAB65" stroke-width="2"/>
                <circle cx="66" cy="65" r="28" fill="#F5C4A0" fill-opacity="0.8" stroke="#E8631A" stroke-width="2"/>
              </svg>
            </div>
            <p style="font-size:11px;color:#ccc;font-family:'Inter',system-ui,sans-serif;margin:0;">3 circles to solve</p>
          </a>
        <% end %>
      </div>
    <% else %>
      <div style="text-align:center;padding:60px 0;">
        <p style="color:#aaa;font-size:15px;font-weight:500;margin:0 0 20px;font-family:'Inter',system-ui,sans-serif;">No puzzles yet — be the first.</p>
        <% if user_signed_in? %>
          <a href="/puzzles/new" style="display:inline-block;font-weight:700;font-size:14px;padding:12px 24px;border-radius:12px;background:#1a1a2e;color:white;text-decoration:none;">Create a puzzle</a>
        <% else %>
          <a href="/users/sign_up" style="display:inline-block;font-weight:700;font-size:14px;padding:12px 24px;border-radius:12px;background:#1a1a2e;color:white;text-decoration:none;">Sign up to create</a>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
