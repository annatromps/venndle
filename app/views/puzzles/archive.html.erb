<% content_for :og_title, "Venndle — Archive" %>
<% content_for :title, "Archive — Venndle" %>

<div style="height:100%;overflow-y:auto;padding:24px 20px 40px;">
  <div style="max-width:600px;margin:0 auto;">
    <h1 style="font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#1a1a2e;margin:0 0 4px;">Archive</h1>
    <p style="font-size:13px;color:#999;margin:0 0 24px;font-family:'Inter',system-ui,sans-serif;">All past daily puzzles</p>

    <div style="display:flex;flex-direction:column;gap:8px;">
      <% @puzzles.each do |puzzle| %>
        <% played     = @played_ids.include?(puzzle.id)
           upcoming   = puzzle.scheduled_date > Date.today
           today      = puzzle.scheduled_date == Date.today
           yesterday  = puzzle.scheduled_date == Date.yesterday
           gs         = @game_sessions_by_puzzle_id[puzzle.id]
           border   = upcoming ? '#e0d9fc' : (today ? '#2BAB65' : 'rgba(0,0,0,0.1)')
           bg       = today ? '#f0fdf4' : 'white' %>
        <div style="display:flex;align-items:center;gap:12px;background:<%= bg %>;border:1.5px solid <%= border %>;border-radius:12px;padding:12px 16px;">
          <div style="flex:1;min-width:0;">
            <div style="font-size:11px;font-weight:600;color:#aaa;letter-spacing:0.05em;text-transform:uppercase;font-family:'Inter',system-ui,sans-serif;margin-bottom:2px;">
              <%= puzzle.scheduled_date.strftime("%-d %B %Y") %>
              <% if @play_counts %>
                <span style="margin-left:6px;color:#bbb;font-weight:500;text-transform:none;letter-spacing:0;"><%= @play_counts[puzzle.id] || 0 %> plays</span>
              <% end %>
              <% if today %>
                <span style="margin-left:6px;background:#dcfce7;color:#16a34a;border-radius:999px;padding:1px 7px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;">Today</span>
              <% elsif upcoming %>
                <span style="margin-left:6px;background:#ede9fe;color:#5B53D6;border-radius:999px;padding:1px 7px;font-size:10px;text-transform:uppercase;letter-spacing:0.06em;">Upcoming</span>
              <% end %>
            </div>
            <div style="font-size:14px;font-weight:600;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              <%= puzzle.title.presence || "Puzzle ##{puzzle.id}" %>
            </div>
          </div>

          <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <% if upcoming %>
              <a href="/daily<%= @day_numbers[puzzle.id] %>"
                 style="background:#ede9fe;color:#5B53D6;font-size:12px;font-weight:700;text-decoration:none;border-radius:8px;padding:6px 14px;font-family:'Inter',system-ui,sans-serif;">
                Preview
              </a>
            <% elsif !user_signed_in? && !today && !yesterday %>
              <a href="<%= new_user_session_path %>"
                 style="background:#f4f4f5;color:#888;font-size:12px;font-weight:600;text-decoration:none;border-radius:8px;padding:6px 14px;font-family:'Inter',system-ui,sans-serif;white-space:nowrap;">
                Sign in to play
              </a>
            <% elsif played && gs %>
              <% share_str = build_share_string_for(gs, puzzle) %>
              <button onclick="archiveShare(this)"
                      data-share="<%= h(share_str) %>"
                      data-game-id="<%= game_id_for(puzzle) %>"
                      style="background:transparent;border:1.5px solid <%= today ? '#bbf7d0' : '#ddd' %>;border-radius:8px;padding:6px 10px;cursor:pointer;display:flex;align-items:center;justify-content:center;"
                      title="Share your score">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
              </button>
              <a href="/daily<%= @day_numbers[puzzle.id] %>"
                 style="background:<%= today ? '#2BAB65' : '#f4f4f5' %>;color:<%= today ? 'white' : '#444' %>;font-size:12px;font-weight:700;text-decoration:none;border-radius:8px;padding:6px 14px;font-family:'Inter',system-ui,sans-serif;white-space:nowrap;">
                View completed
              </a>
            <% else %>
              <a href="/daily<%= @day_numbers[puzzle.id] %>"
                 style="background:<%= today ? '#2BAB65' : '#1a1a2e' %>;color:white;font-size:12px;font-weight:700;text-decoration:none;border-radius:8px;padding:6px 14px;font-family:'Inter',system-ui,sans-serif;">
                <%= today ? "Play today" : "Play" %>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @puzzles.empty? %>
        <p style="text-align:center;color:#aaa;font-size:14px;padding:40px 0;font-family:'Inter',system-ui,sans-serif;">No past puzzles yet.</p>
      <% end %>
    </div>
  </div>
</div>

<script>
  function archiveShare(btn) {
    var text = btn.dataset.share;
    gtag('event', 'share_score', { 'game_id': btn.dataset.gameId });
    if (navigator.share) {
      navigator.share({ text: text }).catch(function(){});
    } else {
      navigator.clipboard.writeText(text).then(function() {
        var orig = btn.innerHTML;
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2BAB65" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(function() { btn.innerHTML = orig; }, 2000);
      });
    }
  }
</script>
