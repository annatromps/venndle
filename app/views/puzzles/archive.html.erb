<% content_for :og_title, "Venndle — Archive" %>
<% content_for :title, "Archive — Venndle" %>

<div style="height:100%;overflow-y:auto;padding:24px 20px 40px;">
  <div style="max-width:600px;margin:0 auto;">
    <h1 style="font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#1a1a2e;margin:0 0 4px;">Archive</h1>
    <p style="font-size:13px;color:#999;margin:0 0 24px;font-family:'Inter',system-ui,sans-serif;">All past daily puzzles</p>

    <div style="display:flex;flex-direction:column;gap:8px;">
      <% @puzzles.each do |puzzle| %>
        <% played = @played_ids.include?(puzzle.id) %>
        <div style="display:flex;align-items:center;gap:12px;background:white;border:1.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:12px 16px;">
          <div style="flex:1;min-width:0;">
            <div style="font-size:11px;font-weight:600;color:#aaa;letter-spacing:0.05em;text-transform:uppercase;font-family:'Inter',system-ui,sans-serif;margin-bottom:2px;">
              <%= puzzle.scheduled_date.strftime("%-d %B %Y") %>
            </div>
            <div style="font-size:14px;font-weight:600;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              <%= puzzle.title.presence || "Puzzle ##{puzzle.id}" %>
            </div>
          </div>
          <% if played %>
            <a href="<%= puzzle_path(puzzle) %>"
               style="flex-shrink:0;background:transparent;color:#2BAB65;font-size:12px;font-weight:700;text-decoration:none;border-radius:8px;padding:6px 14px;border:1.5px solid #2BAB65;font-family:'Inter',system-ui,sans-serif;">
              View score
            </a>
          <% else %>
            <a href="<%= puzzle_path(puzzle) %>"
               style="flex-shrink:0;background:#1a1a2e;color:white;font-size:12px;font-weight:700;text-decoration:none;border-radius:8px;padding:6px 14px;font-family:'Inter',system-ui,sans-serif;">
              Play
            </a>
          <% end %>
        </div>
      <% end %>

      <% if @puzzles.empty? %>
        <p style="text-align:center;color:#aaa;font-size:14px;padding:40px 0;font-family:'Inter',system-ui,sans-serif;">No past puzzles yet.</p>
      <% end %>
    </div>
  </div>
</div>
