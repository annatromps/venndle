<%# Venn diagram + guess cards shared by daily and show views %>
<% game_session ||= nil %>
<% attempts ||= [] %>
<% completed_view ||= false %>

<div id="venn-puzzle" data-puzzle-id="<%= puzzle.id %>">

  <% if game_session&.completed? %>
    <%# ===== SOLVED / COMPLETED STATE ===== %>

    <%# Solved badge %>
    <div style="text-align:center;margin-bottom:14px;">
      <span style="display:inline-block;background:#1a1a2e;color:white;font-size:12px;font-weight:700;border-radius:999px;padding:4px 14px;letter-spacing:0.05em;">
        🎉 SOLVED
      </span>
    </div>

    <h2 style="font-family:'Playfair Display',serif;font-size:40px;font-weight:700;color:#1a1a2e;margin:0 0 6px;text-align:center;">Nicely done.</h2>

    <%# Subtitle — count wrong attempts %>
    <% total_wrong = 0
       %w[a b c].each do |lbl|
         cnt = game_session.send("attempts_#{lbl}")
         solved = game_session.send("solved_#{lbl}?")
         total_wrong += [cnt - (solved ? 1 : 0), 0].max
       end
    %>
    <p style="text-align:center;color:#999;font-size:14px;margin:0 0 20px;">You cracked Puzzle #<%= puzzle.id %> with <%= total_wrong %> <%= total_wrong == 1 ? 'miss' : 'misses' %>.</p>

    <%# Mini Venn diagram — all labels revealed %>
    <div style="background:#f8f8fb;border-radius:18px;padding:12px 8px 8px;margin-bottom:20px;position:relative;">
      <svg viewBox="0 0 560 460" width="100%" style="max-width:560px;display:block;margin:0 auto;" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="pill-shadow-s" x="-20%" y="-40%" width="140%" height="180%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.13"/>
          </filter>
        </defs>

        <%# Circles %>
        <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.5" stroke="#5B53D6" stroke-width="2"/>
        <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.5" stroke="#2BAB65" stroke-width="2"/>
        <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.5" stroke="#E8631A" stroke-width="2"/>

        <%# A label pill — always shown with label revealed %>
        <% a_text = puzzle.label_a.to_s.upcase %>
        <% a_pw = [a_text.length * 8 + 24, 60].max %>
        <rect x="<%= 280 - a_pw/2 %>" y="8" width="<%= a_pw %>" height="28" rx="14" fill="#5B53D6"/>
        <text x="280" y="27" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= a_text %></text>

        <%# B label pill — revealed %>
        <% b_text = puzzle.label_b.to_s.upcase %>
        <% b_pw = [b_text.length * 8 + 24, 60].max %>
        <rect x="<%= 185 - b_pw/2 %>" y="428" width="<%= b_pw %>" height="28" rx="14" fill="#2BAB65"/>
        <text x="185" y="447" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= b_text %></text>

        <%# C label pill — revealed %>
        <% c_text = puzzle.label_c.to_s.upcase %>
        <% c_pw = [c_text.length * 8 + 24, 60].max %>
        <rect x="<%= 375 - c_pw/2 %>" y="428" width="<%= c_pw %>" height="28" rx="14" fill="#E8631A"/>
        <text x="375" y="447" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= c_text %></text>

        <%# Word pills — A only %>
        <% word = puzzle.words_a&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 280 - pw/2 %>" y="59" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="280" y="76" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — B only %>
        <% word = puzzle.words_b&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 112 - pw/2 %>" y="310" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="112" y="327" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — C only %>
        <% word = puzzle.words_c&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 448 - pw/2 %>" y="310" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="448" y="327" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — AB %>
        <% word = puzzle.words_ab&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 208 - pw/2 %>" y="202" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="208" y="219" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — AC %>
        <% word = puzzle.words_ac&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 352 - pw/2 %>" y="202" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="352" y="219" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — BC %>
        <% word = puzzle.words_bc&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 280 - pw/2 %>" y="323" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="280" y="340" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — ABC %>
        <% word = puzzle.words_abc&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 280 - pw/2 %>" y="235" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-s)"/>
          <text x="280" y="252" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>
      </svg>
    </div>

    <%# Read-only answer rows %>
    <% [
      ["a", "#5B53D6", "#EDEAFC", "#9B94E8"],
      ["b", "#2BAB65", "#E5F5EC", "#72C894"],
      ["c", "#E8631A", "#FDF0E9", "#F0956A"]
    ].each do |lbl, color, bg, placeholder_color| %>
      <% label_text = puzzle.send("label_#{lbl}") %>
      <% lbl_attempts = attempts.select { |a| a.label == lbl } %>
      <% cnt = game_session.send("attempts_#{lbl}") %>
      <% solved = game_session.send("solved_#{lbl}?") %>
      <% wrong = [cnt - (solved ? 1 : 0), 0].max %>

      <div style="border:1.5px solid <%= color %>;border-radius:14px;padding:12px 14px;background:<%= bg %>;margin-bottom:10px;display:flex;align-items:center;gap:10px;">
        <%# Badge %>
        <span style="width:28px;height:28px;border-radius:50%;background:<%= color %>;color:white;font-weight:700;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;">
          <%= lbl.upcase %>
        </span>
        <%# Label text %>
        <span style="flex:1;font-weight:600;font-size:14px;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;"><%= label_text %></span>
        <%# Attempt marks %>
        <span style="font-size:13px;letter-spacing:2px;">
          <%= "✗" * wrong %><% if solved %><span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:<%= color %>;color:white;font-size:11px;font-weight:700;margin-left:2px;">✓</span><% end %>
        </span>
      </div>
    <% end %>

    <%# Share card %>
    <% total_wrong_final = 0
       %w[a b c].each do |lbl|
         cnt2 = game_session.send("attempts_#{lbl}")
         solved2 = game_session.send("solved_#{lbl}?")
         total_wrong_final += [cnt2 - (solved2 ? 1 : 0), 0].max
       end
    %>
    <div style="background:white;border:1.5px solid #f0f0f0;border-radius:18px;padding:20px;margin-top:16px;box-shadow:0 2px 12px rgba(0,0,0,0.06);">
      <div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#1a1a2e;margin-bottom:4px;">Venndle #<%= puzzle.id %></div>
      <div style="font-size:13px;color:#888;margin-bottom:14px;">Solved with <%= total_wrong_final %> <%= total_wrong_final == 1 ? 'miss' : 'misses' %> &mdash; share with friends</div>
      <div id="share-string" style="font-size:13px;color:#555;margin-bottom:16px;font-family:monospace;white-space:pre-wrap;line-height:1.8;">
        <%= build_share_string_for(game_session, puzzle) %>
      </div>
      <button onclick="copyShare()" style="width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;height:44px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
        Copy
      </button>
    </div>

    <script>
      function copyShare() {
        const text = document.getElementById('share-string').textContent.trim();
        navigator.clipboard.writeText(text).then(function() {
          const btn = event.target;
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
        });
      }
    </script>

  <% elsif user_signed_in? && game_session %>
    <%# ===== ACTIVE GAME STATE ===== %>

    <%# Venn diagram box %>
    <div style="background:#f8f8fb;border-radius:18px;padding:12px 8px 8px;margin-bottom:20px;position:relative;">
      <svg viewBox="0 0 560 460" width="100%" style="max-width:560px;display:block;margin:0 auto;" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="pill-shadow" x="-20%" y="-40%" width="140%" height="180%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.13"/>
          </filter>
        </defs>

        <%# Circles %>
        <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.5" stroke="#5B53D6" stroke-width="2"/>
        <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.5" stroke="#2BAB65" stroke-width="2"/>
        <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.5" stroke="#E8631A" stroke-width="2"/>

        <%# A label pill — always visible, shows label if known %>
        <% a_display = puzzle.label_a.present? ? puzzle.label_a.upcase : "CIRCLE A" %>
        <% a_pw = [a_display.length * 8 + 24, 60].max %>
        <rect x="<%= 280 - a_pw/2 %>" y="8" width="<%= a_pw %>" height="28" rx="14" fill="#5B53D6"/>
        <text x="280" y="27" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= a_display %></text>

        <%# B label pill %>
        <% b_solved = game_session.solved_b? %>
        <% b_display = b_solved ? puzzle.label_b.to_s.upcase : "?" %>
        <% b_color = b_solved ? "#2BAB65" : "#2d2d2d" %>
        <% b_pw = b_solved ? [b_display.length * 8 + 24, 60].max : 36 %>
        <rect x="<%= 185 - b_pw/2 %>" y="428" width="<%= b_pw %>" height="28" rx="14" fill="<%= b_color %>"/>
        <text x="185" y="447" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= b_display %></text>

        <%# C label pill %>
        <% c_solved = game_session.solved_c? %>
        <% c_display = c_solved ? puzzle.label_c.to_s.upcase : "?" %>
        <% c_color = c_solved ? "#E8631A" : "#2d2d2d" %>
        <% c_pw = c_solved ? [c_display.length * 8 + 24, 60].max : 36 %>
        <rect x="<%= 375 - c_pw/2 %>" y="428" width="<%= c_pw %>" height="28" rx="14" fill="<%= c_color %>"/>
        <text x="375" y="447" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= c_display %></text>

        <%# Word pills — A only %>
        <% word = puzzle.words_a&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 280 - pw/2 %>" y="59" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="280" y="76" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — B only %>
        <% word = puzzle.words_b&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 112 - pw/2 %>" y="310" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="112" y="327" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — C only %>
        <% word = puzzle.words_c&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 448 - pw/2 %>" y="310" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="448" y="327" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — AB %>
        <% word = puzzle.words_ab&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 208 - pw/2 %>" y="202" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="208" y="219" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — AC %>
        <% word = puzzle.words_ac&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 352 - pw/2 %>" y="202" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="352" y="219" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — BC %>
        <% word = puzzle.words_bc&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 280 - pw/2 %>" y="323" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="280" y="340" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>

        <%# Word pills — ABC %>
        <% word = puzzle.words_abc&.first %>
        <% if word %>
          <% pw = [word.length * 8 + 24, 60].max %>
          <rect x="<%= 280 - pw/2 %>" y="235" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
          <text x="280" y="252" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
        <% end %>
      </svg>
    </div>

    <%# Guess rows %>
    <% [
      ["a", "#5B53D6", "#EDEAFC", "#9B94E8"],
      ["b", "#2BAB65", "#E5F5EC", "#72C894"],
      ["c", "#E8631A", "#FDF0E9", "#F0956A"]
    ].each do |lbl, color, bg, placeholder_color| %>
      <% solved = game_session.send("solved_#{lbl}?") %>
      <% label_text = puzzle.send("label_#{lbl}") %>
      <% lbl_attempts = attempts.select { |a| a.label == lbl } %>
      <% wrong_count = lbl_attempts.count { |a| !a.correct? } %>

      <div id="guess-row-<%= lbl %>"
           class="guess-row"
           data-label="<%= lbl %>"
           data-solved="<%= solved %>"
           style="border:1.5px solid <%= color %>;border-radius:14px;padding:12px 14px;background:<%= bg %>;margin-bottom:10px;display:flex;align-items:center;gap:10px;">

        <%# Letter badge %>
        <span style="width:28px;height:28px;border-radius:50%;background:<%= color %>;color:white;font-weight:700;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;">
          <%= lbl.upcase %>
        </span>

        <% if solved %>
          <%# Solved: show label text %>
          <span style="flex:1;font-weight:600;font-size:14px;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;"><%= label_text %></span>
        <% else %>
          <%# Unsolved: input %>
          <input type="text"
                 name="guess"
                 placeholder="Guess circle <%= lbl.upcase %>..."
                 autocomplete="off"
                 style="flex:1;border:none;background:transparent;font-size:14px;font-weight:500;color:#1a1a2e;outline:none;font-family:'Inter',system-ui,sans-serif;min-width:0;::placeholder{color:<%= placeholder_color %>};"
                 data-placeholder-color="<%= placeholder_color %>"
          />
        <% end %>

        <%# Attempt marks %>
        <span id="marks-<%= lbl %>" style="display:flex;align-items:center;gap:3px;flex-shrink:0;">
          <% lbl_attempts.each do |attempt| %>
            <% if attempt.correct? %>
              <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:<%= color %>;color:white;font-size:11px;font-weight:700;">✓</span>
            <% else %>
              <span style="font-size:13px;color:#999;">✗</span>
            <% end %>
          <% end %>
        </span>

        <% if solved %>
          <%# Blue checkmark badge for solved %>
          <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:#2563EB;color:white;font-size:12px;font-weight:700;flex-shrink:0;">✓</span>
        <% end %>
      </div>
    <% end %>

    <%# Submit button %>
    <button id="submit-btn" style="width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:16px;border:none;border-radius:14px;height:52px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;margin-bottom:14px;">
      Submit guess
    </button>

    <%# Attempt counter %>
    <% total_attempts = (game_session.attempts_a || 0) + (game_session.attempts_b || 0) + (game_session.attempts_c || 0) %>
    <div style="display:flex;align-items:center;gap:8px;justify-content:center;margin-bottom:4px;">
      <% 9.times do |i| %>
        <span style="width:8px;height:8px;border-radius:50%;background:<%= i < total_attempts ? '#1a1a2e' : '#ddd' %>;display:inline-block;"></span>
      <% end %>
      <span style="font-size:12px;color:#999;margin-left:4px;font-family:'Inter',system-ui,sans-serif;">Attempt <%= total_attempts %> of 9</span>
    </div>

    <script>
      (function() {
        const puzzleId = "<%= puzzle.id %>";
        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

        // Set placeholder colors via JS since CSS ::placeholder can't be inlined
        document.querySelectorAll('.guess-row input[name="guess"]').forEach(function(input) {
          const color = input.dataset.placeholderColor;
          if (color) {
            const style = document.createElement('style');
            style.textContent = '#guess-row-' + input.closest('.guess-row').dataset.label + ' input::placeholder { color: ' + color + '; opacity: 1; }';
            document.head.appendChild(style);
          }
        });

        document.getElementById('submit-btn').addEventListener('click', async function() {
          const rows = document.querySelectorAll('.guess-row:not([data-solved="true"])');
          const filled = [];
          rows.forEach(function(row) {
            const input = row.querySelector('input[name="guess"]');
            if (input && input.value.trim()) {
              filled.push({ label: row.dataset.label, guess: input.value.trim(), input: input, row: row });
            }
          });
          if (!filled.length) return;

          const btn = document.getElementById('submit-btn');
          btn.disabled = true;
          btn.textContent = 'Checking...';

          for (const item of filled) {
            try {
              const response = await fetch('/puzzles/' + puzzleId + '/guess', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRF-Token': csrfToken
                },
                body: JSON.stringify({ label: item.label, guess: item.guess })
              });
              const data = await response.json();

              // Add attempt mark
              const marksEl = document.getElementById('marks-' + item.label);
              if (data.correct) {
                const mark = document.createElement('span');
                mark.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:' + getCircleColor(item.label) + ';color:white;font-size:11px;font-weight:700;';
                mark.textContent = '✓';
                marksEl.appendChild(mark);
              } else {
                const mark = document.createElement('span');
                mark.style.cssText = 'font-size:13px;color:#999;';
                mark.textContent = '✗';
                marksEl.appendChild(mark);
              }

              item.input.value = '';

              // If solved, update the row
              if (data.solved[item.label]) {
                const row = item.row;
                row.dataset.solved = 'true';
                // Replace input with label text
                const inputEl = row.querySelector('input[name="guess"]');
                if (inputEl) {
                  const labelSpan = document.createElement('span');
                  labelSpan.style.cssText = 'flex:1;font-weight:600;font-size:14px;color:#1a1a2e;font-family:\'Inter\',system-ui,sans-serif;';
                  labelSpan.textContent = data['label_' + item.label];
                  inputEl.replaceWith(labelSpan);
                }
                // Add blue checkmark
                const checkBadge = document.createElement('span');
                checkBadge.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:#2563EB;color:white;font-size:12px;font-weight:700;flex-shrink:0;';
                checkBadge.textContent = '✓';
                row.appendChild(checkBadge);
              }

              // Update attempt counter
              updateAttemptCounter();

              if (data.completed) {
                // Reload page to show completed state server-side
                window.location.reload();
                return;
              }
            } catch(err) {
              console.error('Guess failed:', err);
            }
          }

          btn.disabled = false;
          btn.textContent = 'Submit guess';
        });

        function getCircleColor(label) {
          const colors = { a: '#5B53D6', b: '#2BAB65', c: '#E8631A' };
          return colors[label] || '#1a1a2e';
        }

        function updateAttemptCounter() {
          // We can't easily track this client-side without server state,
          // so just increment the dots count from current visible marks
          let total = 0;
          ['a','b','c'].forEach(function(lbl) {
            const marks = document.getElementById('marks-' + lbl);
            if (marks) total += marks.children.length;
          });
          const dots = document.querySelectorAll('#attempt-dots span');
          dots.forEach(function(dot, i) {
            dot.style.background = i < total ? '#1a1a2e' : '#ddd';
          });
          const counter = document.getElementById('attempt-count-text');
          if (counter) counter.textContent = 'Attempt ' + total + ' of 9';
        }
      })();
    </script>

  <% else %>
    <%# Not signed in %>
    <div style="text-align:center;padding:48px 0;">
      <p style="color:#999;font-size:15px;font-weight:500;margin:0 0 20px;font-family:'Inter',system-ui,sans-serif;">Sign in to play this puzzle.</p>
      <a href="/users/sign_in" style="display:inline-block;font-weight:700;font-size:16px;padding:16px 32px;border-radius:14px;background:#1a1a2e;color:white;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">Sign in to play</a>
    </div>
  <% end %>

</div>
