<%# Venn diagram + guess cards shared by daily and show views %>
<% game_session ||= nil %>
<% attempts ||= [] %>
<% _hard_mode_access = admin_view? || (user_signed_in? && (current_user.hard_mode_tester? || current_user.tester?)) %>
<% hard_mode = _hard_mode_access &&
               request.query_parameters.key?('hard') &&
               request.query_parameters['hard'] != '0' %>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" defer></script>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes pill-ring-pulse { 0%,100%{ stroke-opacity:0.35; stroke-width:2; } 50%{ stroke-opacity:0.85; stroke-width:3.5; } }
  @keyframes shake { 0%,100%{transform:translateX(0)} 15%{transform:translateX(-7px)} 30%{transform:translateX(6px)} 45%{transform:translateX(-5px)} 60%{transform:translateX(4px)} 75%{transform:translateX(-2px)} }
  .pill-unsolved .pill-ring { animation: pill-ring-pulse 2.2s ease-in-out infinite; }
  .popover-shake { animation: shake 0.35s ease; }
  @media (max-width:600px) { #svg-wrapper { flex: none !important; height: calc((100vw - 32px) * 458 / 470); } }
</style>

<div id="venn-puzzle" data-puzzle-id="<%= puzzle.id %>" style="height:100%;position:relative;">

  <% if game_session&.completed? %>
    <%# ===== SOLVED / COMPLETED STATE ===== %>
    <%
      total_wrong = 0
      %w[a b c].each do |lbl|
        cnt = game_session.send("attempts_#{lbl}")
        solved = game_session.send("solved_#{lbl}?")
        total_wrong += [cnt - (solved ? 1 : 0), 0].max
      end
    %>

    <%# ── Score panel ── %>
    <div id="score-panel" style="height:100%;overflow-y:auto;display:flex;flex-direction:column;justify-content:space-between;gap:8px;padding:28px 20px;box-sizing:border-box;max-width:700px;margin:0 auto;width:100%;">

      <%# Nicely done + score boxes + share as one tight group %>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <div>
          <h2 style="font-family:'Playfair Display',serif;font-size:34px;font-weight:700;color:#1a1a2e;margin:0 0 4px;line-height:1.1;">Nicely done.</h2>
          <p style="color:#999;font-size:13px;margin:0;font-family:'Inter',system-ui,sans-serif;">Puzzle #<%= puzzle.id %> &mdash; <%= total_wrong %> <%= total_wrong == 1 ? 'miss' : 'misses' %></p>
        </div>

        <div style="display:flex;flex-direction:column;gap:6px;">
          <% circle_colors = { "a" => ["#5B53D6","#EDEAFC"], "b" => ["#2BAB65","#E5F5EC"], "c" => ["#E8631A","#FDF0E9"] } %>
          <% circle_order_for(attempts).each do |lbl| %>
            <% color, bg = circle_colors[lbl] %>
            <% label_text = puzzle.send("label_#{lbl}") %>
            <% cnt = game_session.send("attempts_#{lbl}") %>
            <% solved = game_session.send("solved_#{lbl}?") %>
            <% wrong = [cnt - (solved ? 1 : 0), 0].max %>
            <div style="display:flex;align-items:center;gap:9px;border:1.5px solid <%= color %>;border-radius:12px;padding:9px 12px;background:<%= bg %>;">
              <span style="width:22px;height:22px;border-radius:50%;background:<%= color %>;color:white;font-weight:700;font-size:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;"><%= lbl.upcase %></span>
              <span style="flex:1;font-weight:600;font-size:13px;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;"><%= label_text %></span>
              <span style="font-size:12px;letter-spacing:2px;color:#aaa;"><%= "✗" * wrong %></span>
              <% if solved %><span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:<%= color %>;color:white;font-size:10px;font-weight:700;">✓</span><% end %>
            </div>
          <% end %>
        </div>

        <% _share_text = build_share_string_for(game_session, puzzle, circle_order: circle_order_for(attempts)) %>
        <% _game_id    = game_id_for(puzzle) %>
        <button onclick="vennShare(<%= _share_text.to_json %>, <%= _game_id.to_json %>)" id="share-score-btn"
                style="width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;height:44px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
          Share score
        </button>
      </div>

      <% if puzzle.puzzle_type == "user" %>
        <div style="text-align:center;">
          <% if user_signed_in? %>
            <% user_rating = current_user.ratings.find_by(puzzle: puzzle) %>
            <p style="font-size:12px;color:#999;margin:0 0 6px;font-family:'Inter',system-ui,sans-serif;">
              <%= user_rating ? "Your rating" : "Rate this puzzle" %>
            </p>
            <div id="stars-container" data-current="<%= user_rating&.score || 0 %>">
              <% 5.times do |i| %>
                <button onclick="submitRating(<%= puzzle.id %>, <%= i+1 %>)"
                        onmouseover="hoverStars(<%= i+1 %>)"
                        onmouseout="resetStars()"
                        data-index="<%= i+1 %>"
                        style="font-size:30px;background:none;border:none;cursor:pointer;padding:0 1px;line-height:1;color:<%= user_rating && (i+1) <= user_rating.score ? '#F59E0B' : '#ddd' %>;">★</button>
              <% end %>
            </div>
            <p id="rating-label" style="font-size:11px;color:#aaa;margin:4px 0 0;font-family:'Inter',system-ui,sans-serif;min-height:16px;"><%= user_rating ? "#{user_rating.score}/5 — thanks!" : "" %></p>
          <% else %>
            <p style="font-size:12px;color:#aaa;margin:0;font-family:'Inter',system-ui,sans-serif;">
              <a href="/users/sign_in" style="color:#5B53D6;font-weight:600;text-decoration:none;">Sign in</a> to rate this puzzle
            </p>
          <% end %>
        </div>
      <% end %>

      <%# Mini stats %>
      <% if user_signed_in? %>
        <%
          _gs = current_user.game_sessions
            .joins(:puzzle)
            .where(puzzles: { puzzle_type: "daily" }, completed: true)
            .where("puzzles.scheduled_date <= ?", Date.today)
            .includes(:puzzle).to_a
          _dates = _gs.map { |s| s.puzzle.scheduled_date }.to_set
          _sd = _dates.include?(Date.today) ? Date.today : Date.today - 1
          _streak = 0; _d = _sd
          while _dates.include?(_d); _streak += 1; _d -= 1; end
          _misses = _gs.map { |s|
            (s.attempts_a - (s.gave_up_a? ? 0 : 1)) +
            (s.attempts_b - (s.gave_up_b? ? 0 : 1)) +
            (s.attempts_c - (s.gave_up_c? ? 0 : 1))
          }
          _avg = _misses.empty? ? nil : (_misses.sum.to_f / _misses.size).round(1)
        %>
        <div style="display:flex;align-items:center;gap:0;background:#f7f6fe;border-radius:12px;padding:10px 14px;font-family:'Inter',system-ui,sans-serif;">
          <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
            <% if _streak > 0 %><span style="font-size:15px;line-height:1;margin-right:2px;">🔥</span><% end %>
            <span style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;"><%= _streak %></span>
            <span style="font-size:11px;color:#aaa;font-weight:500;">day streak</span>
          </div>
          <div style="width:1px;height:22px;background:#e0ddf7;margin:0 12px;flex-shrink:0;"></div>
          <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
            <span style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;"><%= _avg || '—' %></span>
            <span style="font-size:11px;color:#aaa;font-weight:500;">avg misses</span>
          </div>
          <a href="/my/stats" style="font-size:11px;font-weight:700;color:#5B53D6;text-decoration:none;flex-shrink:0;margin-left:8px;">All stats →</a>
        </div>
      <% else %>
        <div id="guest-stats-block" style="display:none;background:#f7f6fe;border-radius:12px;padding:10px 14px;font-family:'Inter',system-ui,sans-serif;">
          <div style="display:flex;align-items:center;gap:0;">
            <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
              <span id="guest-streak-fire" style="font-size:15px;line-height:1;margin-right:2px;display:none;">🔥</span>
              <span id="guest-streak-num" style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;">0</span>
              <span style="font-size:11px;color:#aaa;font-weight:500;">day streak</span>
            </div>
            <div style="width:1px;height:22px;background:#e0ddf7;margin:0 12px;flex-shrink:0;"></div>
            <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
              <span id="guest-avg-num" style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;">—</span>
              <span style="font-size:11px;color:#aaa;font-weight:500;">avg misses</span>
            </div>
          </div>
        </div>
      <% end %>

      <%# Other CTAs %>
      <div style="display:flex;flex-direction:column;gap:8px;">
<button onclick="showDiagramPanel()" style="width:100%;background:transparent;border:1.5px solid rgba(0,0,0,0.15);color:#1a1a2e;font-weight:600;font-size:13px;border-radius:12px;height:40px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
  View completed puzzle
</button>
        <div style="display:flex;gap:8px;">
          <a href="/puzzles/new"
             style="flex:1;display:flex;align-items:center;justify-content:center;background:transparent;border:1.5px solid #E8631A;color:#E8631A;font-weight:700;font-size:13px;border-radius:12px;height:40px;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">
            + Create
          </a>
          <div style="flex:1;position:relative;">
            <button onclick="togglePlayMoreMenu(event)"
                    style="width:100%;background:transparent;border:1.5px solid #5B53D6;color:#5B53D6;font-weight:700;font-size:13px;border-radius:12px;height:40px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
              Play more ▾
            </button>
            <div id="play-more-menu" style="display:none;position:absolute;bottom:calc(100% + 6px);left:0;right:0;background:white;border:1px solid #eee;border-radius:12px;box-shadow:0 4px 16px rgba(0,0,0,0.1);overflow:hidden;z-index:100;">
              <a href="/archive" style="display:block;padding:12px 16px;font-size:13px;font-weight:600;color:#1a1a2e;text-decoration:none;font-family:'Inter',system-ui,sans-serif;border-bottom:1px solid #f0f0f0;">Daily archive</a>
              <a href="/puzzles" style="display:block;padding:12px 16px;font-size:13px;font-weight:600;color:#1a1a2e;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">Community created</a>
            </div>
          </div>
        </div>
      </div>

      <% unless user_signed_in? %>
        <div style="text-align:center;padding-top:4px;">
          <p style="font-size:12px;color:#aaa;margin:0 0 6px;font-family:'Inter',system-ui,sans-serif;">Sign up to sync your stats across devices and create puzzles</p>
          <a href="/users/sign_up" style="font-size:12px;font-weight:700;color:#5B53D6;text-decoration:none;">Create a free account &rarr;</a>
        </div>
      <% end %>
    </div>

    <%# ── Diagram panel (fixed overlay, shown by "View completed puzzle") ── %>
    <div id="diagram-panel" style="display:none;position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg,#ede8fb 0%,#fae3d5 100%);z-index:100;flex-direction:column;gap:8px;padding:20px;box-sizing:border-box;">
      <div style="flex:1;min-height:0;overflow:hidden;">
        <svg viewBox="45 -4 470 440" style="width:100%;height:100%;display:block;" preserveAspectRatio="xMidYMin meet" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="pill-shadow-d" x="-20%" y="-40%" width="140%" height="180%">
              <feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.13"/>
            </filter>
          </defs>

          <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.5" stroke="#5B53D6" stroke-width="2"/>
          <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.5" stroke="#2BAB65" stroke-width="2"/>
          <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.5" stroke="#E8631A" stroke-width="2"/>

          <% a_pw = [puzzle.label_a.to_s.upcase.length * 9 + 24, 62].max %>
          <rect x="<%= 280 - a_pw/2 %>" y="8" width="<%= a_pw %>" height="28" rx="14" fill="#5B53D6"/>
          <text x="280" y="27" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= puzzle.label_a.to_s.upcase %></text>

          <% b_pw = [puzzle.label_b.to_s.upcase.length * 9 + 24, 62].max %>
          <rect x="<%= 185 - b_pw/2 %>" y="399" width="<%= b_pw %>" height="28" rx="14" fill="#2BAB65"/>
          <text x="185" y="418" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= puzzle.label_b.to_s.upcase %></text>

          <% c_pw = [puzzle.label_c.to_s.upcase.length * 9 + 24, 62].max %>
          <rect x="<%= 375 - c_pw/2 %>" y="399" width="<%= c_pw %>" height="28" rx="14" fill="#E8631A"/>
          <text x="375" y="418" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= puzzle.label_c.to_s.upcase %></text>

          <% { words_a: [280,59,78], words_b: [112,310,329], words_c: [448,310,329],
               words_ab: [208,202,221], words_ac: [352,202,221],
               words_bc: [280,323,342], words_abc: [280,235,254] }.each do |region, (cx,ry,ty)| %>
            <% word = puzzle.send(region)&.first %>
            <% if word %>
              <% pw = [word.length * 9 + 24, 62].max %>
              <rect x="<%= cx - pw/2 %>" y="<%= ry %>" width="<%= pw %>" height="28" rx="14" fill="#ffffff" filter="url(#pill-shadow-d)"/>
              <text x="<%= cx %>" y="<%= ty %>" text-anchor="middle" font-size="15" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
            <% end %>
          <% end %>
        </svg>
      </div>
      <button onclick="showScorePanel()"
              style="flex-shrink:0;width:100%;background:transparent;border:1.5px solid rgba(0,0,0,0.15);color:#1a1a2e;font-weight:600;font-size:13px;border-radius:12px;height:40px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
        ← Back to results
      </button>
    </div>

    <script>
      <%# vennShare and vennCopyFallback live in app/javascript/venn_share.js — do not re-define here %>

      function showDiagramPanel() {
        var dp = document.getElementById('diagram-panel');
        if (dp) dp.style.display = 'flex';
      }

      function showScorePanel() {
        var dp = document.getElementById('diagram-panel');
        if (dp) dp.style.display = 'none';
      }

      function togglePlayMoreMenu(event) {
        event.stopPropagation();
        var menu = document.getElementById('play-more-menu');
        var isOpen = menu.style.display !== 'none';
        menu.style.display = isOpen ? 'none' : 'block';
        if (!isOpen) {
          document.addEventListener('click', function closeMenu() {
            menu.style.display = 'none';
            document.removeEventListener('click', closeMenu);
          });
        }
      }

      function hoverStars(n) {
        document.querySelectorAll('#stars-container button[data-index]').forEach(function(btn) {
          btn.style.color = parseInt(btn.dataset.index) <= n ? '#FBBF24' : '#ddd';
        });
      }

      function resetStars() {
        var container = document.getElementById('stars-container');
        if (!container) return;
        var current = parseInt(container.dataset.current || 0);
        document.querySelectorAll('#stars-container button[data-index]').forEach(function(btn) {
          btn.style.color = parseInt(btn.dataset.index) <= current ? '#F59E0B' : '#ddd';
        });
      }

      <% unless user_signed_in? %>
      (function() {
        var isDaily = <%= (puzzle.puzzle_type == 'daily').to_json %>;
        var puzzleDate = <%= puzzle.scheduled_date&.to_s.to_json %>;
        var misses = <%= total_wrong %>;
        try {
          var saved = JSON.parse(localStorage.getItem('venndle_daily_stats') || '{}');
          if (isDaily && puzzleDate && !saved[puzzleDate]) {
            saved[puzzleDate] = { misses: misses };
            localStorage.setItem('venndle_daily_stats', JSON.stringify(saved));
          }
          if (Object.keys(saved).length === 0) return;
          function ds(d) {
            return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
          }
          var now = new Date();
          var today = ds(now), yesterday = ds(new Date(now - 86400000));
          var start = saved[today] ? today : (saved[yesterday] ? yesterday : null);
          var streak = 0;
          if (start) {
            var d = new Date(start + 'T12:00:00');
            while (saved[ds(d)]) { streak++; d.setDate(d.getDate() - 1); }
          }
          var vals = Object.values(saved).map(function(v) { return v.misses; });
          var avg = vals.length ? Math.round(vals.reduce(function(a,b){return a+b;},0) / vals.length * 10) / 10 : null;
          document.getElementById('guest-streak-num').textContent = streak;
          if (streak > 0) document.getElementById('guest-streak-fire').style.display = '';
          document.getElementById('guest-avg-num').textContent = avg !== null ? avg : '—';
          document.getElementById('guest-stats-block').style.display = '';
        } catch(e) {}
      })();
      <% end %>

      function submitRating(puzzleId, score) {
        var csrf = document.querySelector('meta[name="csrf-token"]').content;
        fetch('/puzzles/' + puzzleId + '/rating', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
          body: JSON.stringify({ score: score })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            var container = document.getElementById('stars-container');
            container.dataset.current = score;
            document.querySelectorAll('#stars-container button[data-index]').forEach(function(btn) {
              btn.style.color = parseInt(btn.dataset.index) <= score ? '#F59E0B' : '#ddd';
            });
            var label = document.getElementById('rating-label');
            if (label) label.textContent = score + '/5 — thanks!';
          }
        });
      }
    </script>

  <% elsif game_session %>
    <%# ===== ACTIVE GAME STATE — tap-to-guess popover ===== %>
    <%
      a_solved = game_session.solved_a?
      b_solved = game_session.solved_b?
      c_solved = game_session.solved_c?
      a_display = a_solved ? puzzle.label_a.to_s.upcase : "A"
      b_display = b_solved ? puzzle.label_b.to_s.upcase : "B"
      c_display = c_solved ? puzzle.label_c.to_s.upcase : "C"
      a_pw = [a_display.length * 9 + 24, 62].max
      b_pw = [b_display.length * 9 + 24, 62].max
      c_pw = [c_display.length * 9 + 24, 62].max
    %>

    <div style="height:100%;display:flex;flex-direction:column;">

      <%# SVG diagram — fills all space; position:relative hosts the popover %>
      <div id="svg-wrapper" style="flex:1;min-height:0;overflow:hidden;position:relative;">
        <svg id="venn-svg" viewBox="45 -4 470 458" style="width:100%;height:100%;display:block;" preserveAspectRatio="xMidYMin meet" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="pill-shadow" x="-20%" y="-40%" width="140%" height="180%">
              <feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.13"/>
            </filter>
          </defs>

          <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.5" stroke="#5B53D6" stroke-width="2"/>
          <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.5" stroke="#2BAB65" stroke-width="2"/>
          <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.5" stroke="#E8631A" stroke-width="2"/>

          <%# A label pill %>
          <g id="pill-a" data-label-pill="a" data-cx="280" data-solved-color="#5B53D6"<% unless a_solved %> class="pill-unsolved" style="cursor:pointer;"<% end %>>
            <% unless a_solved %>
              <rect class="pill-ring" x="<%= 280 - a_pw/2 - 4 %>" y="4" width="<%= a_pw + 8 %>" height="36" rx="18" fill="none" stroke="#5B53D6" stroke-width="2"/>
            <% end %>
            <rect x="<%= 280 - a_pw/2 %>" y="8" width="<%= a_pw %>" height="28" rx="14" fill="#5B53D6"/>
            <text x="280" y="27" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= a_display %></text>
            <text id="ctr-a" x="280" y="52" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui,sans-serif"><tspan id="ctr-a-x" fill="#e53e3e"></tspan><tspan id="ctr-a-h" fill="#d97706"></tspan><tspan id="ctr-a-ok" fill="#16a34a"></tspan></text>
          </g>

          <%# B label pill %>
          <g id="pill-b" data-label-pill="b" data-cx="185" data-solved-color="#2BAB65"<% unless b_solved %> class="pill-unsolved" style="cursor:pointer;"<% end %>>
            <% unless b_solved %>
              <rect class="pill-ring" x="<%= 185 - b_pw/2 - 4 %>" y="395" width="<%= b_pw + 8 %>" height="36" rx="18" fill="none" stroke="#2BAB65" stroke-width="2"/>
            <% end %>
            <rect x="<%= 185 - b_pw/2 %>" y="399" width="<%= b_pw %>" height="28" rx="14" fill="#2BAB65"/>
            <text x="185" y="418" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= b_display %></text>
            <text id="ctr-b" x="185" y="448" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui,sans-serif"><tspan id="ctr-b-x" fill="#e53e3e"></tspan><tspan id="ctr-b-h" fill="#d97706"></tspan><tspan id="ctr-b-ok" fill="#16a34a"></tspan></text>
          </g>

          <%# C label pill %>
          <g id="pill-c" data-label-pill="c" data-cx="375" data-solved-color="#E8631A"<% unless c_solved %> class="pill-unsolved" style="cursor:pointer;"<% end %>>
            <% unless c_solved %>
              <rect class="pill-ring" x="<%= 375 - c_pw/2 - 4 %>" y="395" width="<%= c_pw + 8 %>" height="36" rx="18" fill="none" stroke="#E8631A" stroke-width="2"/>
            <% end %>
            <rect x="<%= 375 - c_pw/2 %>" y="399" width="<%= c_pw %>" height="28" rx="14" fill="#E8631A"/>
            <text x="375" y="418" text-anchor="middle" font-size="13" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= c_display %></text>
            <text id="ctr-c" x="375" y="448" text-anchor="middle" font-size="11" font-weight="700" font-family="system-ui,sans-serif"><tspan id="ctr-c-x" fill="#e53e3e"></tspan><tspan id="ctr-c-h" fill="#d97706"></tspan><tspan id="ctr-c-ok" fill="#16a34a"></tspan></text>
          </g>

          <%# Word pills %>
          <% { words_a: [280,59,78], words_b: [112,310,329], words_c: [448,310,329],
               words_ab: [208,202,221], words_ac: [352,202,221],
               words_bc: [280,323,342], words_abc: [280,235,254] }.each do |region, (cx,ry,ty)| %>
            <% word = puzzle.send(region)&.first %>
            <% if word %>
              <% pw = [word.length * 9 + 24, 62].max %>
              <rect x="<%= cx - pw/2 %>" y="<%= ry %>" width="<%= pw %>" height="28" rx="14" fill="#FAF6EE" filter="url(#pill-shadow)"/>
              <text x="<%= cx %>" y="<%= ty %>" text-anchor="middle" font-size="15" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
            <% end %>
          <% end %>
        </svg>

        <%# Floating guess popover — repositioned by JS when a pill is clicked %>
        <div id="label-popover"
             style="display:none;position:absolute;z-index:200;width:220px;background:white;border-radius:14px;box-shadow:0 8px 28px rgba(0,0,0,0.18);padding:12px;box-sizing:border-box;border:1.5px solid #5B53D6;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span id="popover-badge"
                  style="width:22px;height:22px;border-radius:50%;background:#5B53D6;color:white;font-weight:700;font-size:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;">A</span>
            <span id="popover-marks" style="flex:1;display:flex;gap:2px;flex-wrap:wrap;align-items:center;min-height:16px;"></span>
            <button onclick="closePopover()" style="background:none;border:none;cursor:pointer;color:#bbb;font-size:15px;line-height:1;padding:0;flex-shrink:0;">✕</button>
          </div>
          <div style="display:flex;align-items:center;gap:6px;background:#f5f5f5;border-radius:10px;padding:5px 8px;margin-bottom:8px;">
            <span id="popover-hint-prefix" style="font-size:13px;font-weight:700;color:#bbb;letter-spacing:1px;white-space:nowrap;font-family:'Inter',system-ui,sans-serif;line-height:1;flex-shrink:0;"></span>
            <input id="popover-input" type="text"
                   placeholder="Category A..."
                   autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false"
                   style="flex:1;min-width:0;border:none;background:transparent;font-size:13px;font-weight:500;color:#1a1a2e;outline:none;font-family:'Inter',system-ui,sans-serif;"/>
            <button id="popover-submit"
                    style="flex-shrink:0;background:#5B53D6;color:white;font-weight:700;font-size:15px;border:none;border-radius:999px;width:32px;height:32px;padding:0;cursor:pointer;font-family:'Inter',system-ui,sans-serif;line-height:1;display:flex;align-items:center;justify-content:center;-webkit-appearance:none;"><svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
          </div>
          <div style="display:flex;gap:10px;align-items:center;">
            <button id="popover-hint-btn"
                    style="font-size:11px;color:#999;background:none;border:none;cursor:pointer;padding:0;font-family:'Inter',system-ui,sans-serif;text-decoration:underline;text-underline-offset:2px;">Reveal letter</button>
            <span style="color:#ddd;font-size:10px;">|</span>
            <button id="popover-give-up-btn"
                    style="font-size:11px;color:#e53e3e;background:none;border:none;cursor:pointer;padding:0;font-family:'Inter',system-ui,sans-serif;text-decoration:underline;text-underline-offset:2px;">Give up</button>
          </div>
          <div id="popover-error" style="display:none;font-size:11px;font-weight:600;color:#e53e3e;margin-top:6px;"></div>
        </div>
      </div>

      <p style="flex-shrink:0;text-align:center;font-size:14px;color:#666666;font-family:'Inter',system-ui,sans-serif;margin:12px 0 0;line-height:1;font-style:italic;">👆 Tap A, B or C to answer</p>

    </div>

    <script>
      (function() {
        const puzzleId  = "<%= puzzle.id %>";
        const gameId    = "<%= game_id_for(puzzle) %>";
        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

        const COLORS = { a: '#5B53D6', b: '#2BAB65', c: '#E8631A' };

        let activeLabel = null;

        const solvedLabels = new Set(<%= [
          (a_solved ? 'a' : nil),
          (b_solved ? 'b' : nil),
          (c_solved ? 'c' : nil)
        ].compact.to_json.html_safe %>);

        const hintState = {
          a: { revealed: [], done: false },
          b: { revealed: [], done: false },
          c: { revealed: [], done: false }
        };

        const attemptMarks = { a: [], b: [], c: [] };
        <% attempts.each do |att| %>
        attemptMarks[<%= att.label.to_json %>].push({ correct: <%= att.correct?.to_json %> });
        <% end %>

        function updatePillCounter(lbl) {
          var misses = attemptMarks[lbl].filter(function(m) { return !m.correct; }).length;
          var hints  = hintState[lbl].revealed.length;
          var solved = solvedLabels.has(lbl);
          var xEl  = document.getElementById('ctr-' + lbl + '-x');
          var hEl  = document.getElementById('ctr-' + lbl + '-h');
          var okEl = document.getElementById('ctr-' + lbl + '-ok');
          if (!xEl) return;
          xEl.textContent  = '✗'.repeat(misses);
          hEl.textContent  = hints  > 0 ? (misses > 0 ? ' ' : '') + '💡'.repeat(hints) : '';
          okEl.textContent = solved ? ((misses + hints) > 0 ? ' ✓' : '✓') : '';
        }
        ['a','b','c'].forEach(updatePillCounter);

        function markHtml(label, correct) {
          const color = COLORS[label];
          if (correct) {
            return '<span style="display:inline-flex;align-items:center;justify-content:center;width:12px;height:12px;border-radius:50%;background:' + color + ';color:white;font-size:7px;font-weight:700;">✓</span>';
          }
          return '<span style="font-size:16px;color:#ef4444;font-weight:900;line-height:1;">✗</span>';
        }

        function renderMarks(label) {
          return attemptMarks[label].map(function(m) { return markHtml(label, m.correct); }).join('');
        }

        window.openPopover = function(label) {
          if (solvedLabels.has(label)) return;
          activeLabel = label;
          const color = COLORS[label];

          document.getElementById('popover-badge').textContent = label.toUpperCase();
          document.getElementById('popover-badge').style.background = color;
          document.getElementById('label-popover').style.borderColor = color;
          document.getElementById('popover-marks').innerHTML = renderMarks(label);

          const state = hintState[label];
          document.getElementById('popover-hint-prefix').textContent = state.revealed.join('');

          const input = document.getElementById('popover-input');
          input.value = '';
          input.placeholder = 'Category ' + label.toUpperCase() + '...';

          const submitBtn = document.getElementById('popover-submit');
          submitBtn.style.background = color;
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

          const hintBtn = document.getElementById('popover-hint-btn');
          if (state.done) {
            hintBtn.disabled = true; hintBtn.style.color = '#bbb'; hintBtn.style.textDecoration = 'none'; hintBtn.textContent = 'All revealed';
          } else {
            hintBtn.disabled = false; hintBtn.style.color = '#999'; hintBtn.style.textDecoration = 'underline'; hintBtn.textContent = 'Reveal letter';
          }

          const errEl = document.getElementById('popover-error');
          errEl.style.display = 'none'; errEl.textContent = '';

          positionPopover(label);
          document.getElementById('label-popover').style.display = 'block';
          setTimeout(function() { input.focus(); }, 50);
        };

        function positionPopover(label) {
          const wrapper = document.getElementById('svg-wrapper');
          const pill    = document.getElementById('pill-' + label);
          const popover = document.getElementById('label-popover');
          if (!wrapper || !pill) return;

          const wRect = wrapper.getBoundingClientRect();
          const pRect = pill.getBoundingClientRect();
          const popW  = 220, popH = 130;

          let left = pRect.left - wRect.left + pRect.width / 2 - popW / 2;
          left = Math.max(8, Math.min(left, wRect.width - popW - 8));

          let top;
          if (label === 'a') {
            top = pRect.bottom - wRect.top + 8;
          } else {
            top = pRect.top - wRect.top - popH - 8;
          }
          top = Math.max(8, Math.min(top, wRect.height - popH - 8));

          popover.style.left = left + 'px';
          popover.style.top  = top  + 'px';
        }

        window.closePopover = function() {
          document.getElementById('label-popover').style.display = 'none';
          activeLabel = null;
        };

        document.addEventListener('click', function(e) {
          const popover = document.getElementById('label-popover');
          if (!popover || popover.style.display === 'none') return;
          if (!popover.contains(e.target) && !e.target.closest('[id^="pill-"]')) closePopover();
        });

        document.getElementById('venn-svg').addEventListener('click', function(e) {
          const pill = e.target.closest('[data-label-pill]');
          if (!pill || solvedLabels.has(pill.dataset.labelPill)) return;
          openPopover(pill.dataset.labelPill);
        });

        // iOS Safari: synthetic click events stop working after SVG DOM mutations.
        // touchstart uses a separate hit-testing path unaffected by this bug.
        document.getElementById('venn-svg').addEventListener('touchstart', function(e) {
          const pill = e.target.closest('[data-label-pill]');
          if (!pill || solvedLabels.has(pill.dataset.labelPill)) return;
          e.preventDefault();
          openPopover(pill.dataset.labelPill);
        }, { passive: false });

        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closePopover();
        });

        function showPopoverError(msg) {
          const el = document.getElementById('popover-error');
          el.textContent = msg; el.style.display = 'block';
          setTimeout(function() { el.style.display = 'none'; el.textContent = ''; }, 4000);
        }

        function removePillInteractivity(label) {
          const pillEl = document.getElementById('pill-' + label);
          if (!pillEl) return;
          pillEl.style.cursor = 'default';
          pillEl.classList.remove('pill-unsolved');
          const ring = pillEl.querySelector('.pill-ring');
          if (ring) ring.remove();
        }

        function updateSvgPill(label, text, color) {
          const g = document.getElementById('pill-' + label);
          if (!g) return;
          const cx = parseFloat(g.dataset.cx);
          const filledRect = Array.from(g.querySelectorAll('rect')).find(function(r) { return !r.classList.contains('pill-ring'); });
          const textEl = g.querySelector('text');
          if (!filledRect || !textEl) return;
          const display = text.toUpperCase();
          const pw = Math.max(display.length * 8 + 24, 60);
          filledRect.setAttribute('fill', color);
          filledRect.setAttribute('width', pw);
          filledRect.setAttribute('x', cx - pw / 2);
          textEl.textContent = display;
          // Force iOS Safari to revalidate SVG hit-test regions after DOM mutation
          const svgEl = document.getElementById('venn-svg');
          if (svgEl) svgEl.getBoundingClientRect();
        }

        async function submitGuess() {
          const label = activeLabel;
          if (!label) return;
          const prefix = document.getElementById('popover-hint-prefix').textContent;
          const input  = document.getElementById('popover-input');
          const guess  = prefix + input.value.trim();
          if (!guess.trim()) return;

          const submitBtn = document.getElementById('popover-submit');
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span style="display:inline-block;animation:spin 0.8s linear infinite;">↻</span>';

          try {
            const resp = await fetch('/puzzles/' + puzzleId + '/guess', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
              body: JSON.stringify({ label: label, guess: guess })
            });

            let data;
            try { data = await resp.json(); }
            catch(e) {
              showPopoverError('Server error');
              submitBtn.disabled = false; submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>'; return;
            }

            if (!resp.ok || data.error) {
              showPopoverError(data.error || 'Something went wrong');
              submitBtn.disabled = false; submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>'; return;
            }

            if (data.duplicate) {
              showPopoverError('You already tried that');
              submitBtn.disabled = false; submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
              input.value = ''; return;
            }

            if (data.board_word) {
              showPopoverError("Can't submit board words");
              submitBtn.disabled = false; submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>'; return;
            }

            attemptMarks[label].push({ correct: data.correct });
            document.getElementById('popover-marks').innerHTML = renderMarks(label);
            input.value = '';

            if (!data.correct) {
              const pop = document.getElementById('label-popover');
              pop.classList.remove('popover-shake');
              void pop.offsetWidth;
              pop.classList.add('popover-shake');
              showPopoverError('Not quite — try again!');
              updatePillCounter(label);
              submitBtn.disabled = false; submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>'; return;
            }

            updateSvgPill(label, data.official_label, COLORS[label]);
            solvedLabels.add(label);
            removePillInteractivity(label);
            updatePillCounter(label);
            try { gtag('event', 'correct_guess', { 'answer_level': label.toUpperCase(), 'game_id': gameId }); } catch(e) {}
            closePopover();

            // Mini burst from the solved pill
            try {
              if (typeof confetti === 'function') {
                const pillEl = document.getElementById('pill-' + label);
                if (pillEl) {
                  const r = pillEl.getBoundingClientRect();
                  confetti({ particleCount: 28, spread: 55, startVelocity: 22, decay: 0.88, ticks: 75,
                    origin: { x: (r.left + r.width / 2) / window.innerWidth,
                               y: (r.top  + r.height / 2) / window.innerHeight },
                    colors: [COLORS[label], '#ffffff', '#ffd700'] });
                }
              }
            } catch(e) {}

            if (data.completed) {
              try { gtag('event', 'game_complete', { 'game_id': gameId }); } catch(e) {}
              const isPerfect = ['a','b','c'].every(function(lbl) {
                return attemptMarks[lbl].length === 1 && hintState[lbl].revealed.length === 0;
              });
              if (isPerfect && typeof confetti === 'function') {
                const opts = { particleCount: 120, spread: 70, startVelocity: 60, decay: 0.92, ticks: 200,
                  colors: ['#5B53D6','#2BAB65','#E8631A','#ffffff','#ffd700'] };
                confetti(Object.assign({}, opts, { angle: 60,  origin: { x: 0, y: 1 } }));
                confetti(Object.assign({}, opts, { angle: 120, origin: { x: 1, y: 1 } }));
                setTimeout(function() { window.location.reload(); }, 2600);
              } else {
                setTimeout(function() { window.location.reload(); }, 700);
              }
            }
          } catch(err) {
            console.error('Guess fetch failed:', err);
            showPopoverError('Network error — please try again');
            submitBtn.disabled = false; submitBtn.innerHTML = '<svg width="16" height="12" viewBox="0 0 16 12" fill="none" style="display:block;"><path d="M0 6h13M9 1l5 5-5 5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          }
        }

        async function fetchHint() {
          const label = activeLabel;
          if (!label || solvedLabels.has(label)) return;
          const state  = hintState[label];
          const btn    = document.getElementById('popover-hint-btn');
          if (btn && btn.disabled) return;
          if (btn) btn.disabled = true;

          try {
            const resp = await fetch('/puzzles/' + puzzleId + '/hint', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
              body: JSON.stringify({ label: label, revealed_count: state.revealed.length })
            });
            const data = await resp.json();

            if (data.done) {
              state.done = true;
              if (btn) { btn.disabled = true; btn.style.color = '#bbb'; btn.style.textDecoration = 'none'; btn.textContent = 'All revealed'; }
              return;
            }

            try { gtag('event', 'use_hint', { 'answer_level': label.toUpperCase(), 'game_id': gameId }); } catch(e) {}
            state.revealed.push(data.letter.toUpperCase());
            document.getElementById('popover-hint-prefix').textContent = state.revealed.join('');
            updatePillCounter(label);

            const input = document.getElementById('popover-input');
            if (input) {
              input.placeholder = state.revealed.length < data.total_length ? '...' : '';
              input.focus();
            }

            if (state.revealed.length >= data.total_length) {
              state.done = true;
              if (btn) { btn.disabled = true; btn.style.color = '#bbb'; btn.style.textDecoration = 'none'; btn.textContent = 'All revealed'; }
            } else {
              if (btn) btn.disabled = false;
            }
          } catch(err) {
            console.error('Hint fetch failed:', err);
            if (btn) btn.disabled = false;
          }
        }

        async function giveUp() {
          const label = activeLabel;
          if (!label) return;
          if (!confirm('Give up on circle ' + label.toUpperCase() + '? This will reveal the answer.')) return;
          const btn = document.getElementById('popover-give-up-btn');
          if (btn) btn.disabled = true;

          try {
            const resp = await fetch('/puzzles/' + puzzleId + '/give_up', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
              body: JSON.stringify({ label: label })
            });
            const data = await resp.json();

            if (!resp.ok || data.already_solved) { if (btn) btn.disabled = false; return; }

            try { gtag('event', 'game_give_up', { 'answer_level': label.toUpperCase(), 'game_id': gameId }); } catch(e) {}
            updateSvgPill(label, data.official_label, COLORS[label]);
            solvedLabels.add(label);
            removePillInteractivity(label);
            closePopover();

            if (data.completed) {
              try { gtag('event', 'game_complete', { 'game_id': gameId }); } catch(e) {}
              window.location.reload();
            }
          } catch(err) {
            console.error('Give up fetch failed:', err);
            if (btn) btn.disabled = false;
          }
        }

        document.getElementById('popover-submit').addEventListener('click', submitGuess);
        document.getElementById('popover-input').addEventListener('keydown', function(e) {
          if (e.key === 'Enter') submitGuess();
        });
        document.getElementById('popover-hint-btn').addEventListener('click', fetchHint);
        document.getElementById('popover-give-up-btn').addEventListener('click', giveUp);
      })();
    </script>

  <% end %>

</div>
