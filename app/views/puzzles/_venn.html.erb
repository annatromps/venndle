<%# Venn diagram + guess cards shared by daily and show views %>
<% game_session ||= nil %>
<% attempts ||= [] %>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js" defer></script>

<style>
  /* Responsive guess area — row on desktop, column on mobile */
  .guess-area { display:flex; flex-shrink:0; gap:8px; flex-direction:column; }
  @media (min-width:520px) {
    .guess-area { flex-direction:row; }
    .guess-area .guess-row { flex:1; min-width:0; }
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .submit-btn-loading { animation: spin 0.8s linear infinite; display:inline-block; }
</style>

<div id="venn-puzzle" data-puzzle-id="<%= puzzle.id %>" style="height:100%;position:relative;">

  <% if game_session&.completed? %>
    <%# ===== SOLVED / COMPLETED STATE ===== %>
    <%
      total_wrong = 0
      %w[a b c].each do |lbl|
        cnt = game_session.send("attempts_#{lbl}")
        solved = game_session.send("solved_#{lbl}?")
        total_wrong += [cnt - (solved ? 1 : 0), 0].max
      end
    %>

    <%# ── Score panel ── %>
    <div id="score-panel" style="height:100%;overflow-y:auto;display:flex;flex-direction:column;justify-content:space-between;gap:8px;padding:28px 20px;box-sizing:border-box;max-width:700px;margin:0 auto;width:100%;">

      <%# Nicely done + score boxes + share as one tight group %>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <div>
          <h2 style="font-family:'Playfair Display',serif;font-size:34px;font-weight:700;color:#1a1a2e;margin:0 0 4px;line-height:1.1;">Nicely done.</h2>
          <p style="color:#999;font-size:13px;margin:0;font-family:'Inter',system-ui,sans-serif;">Puzzle #<%= puzzle.id %> &mdash; <%= total_wrong %> <%= total_wrong == 1 ? 'miss' : 'misses' %></p>
        </div>

        <div style="display:flex;flex-direction:column;gap:6px;">
          <% circle_colors = { "a" => ["#5B53D6","#EDEAFC"], "b" => ["#2BAB65","#E5F5EC"], "c" => ["#E8631A","#FDF0E9"] } %>
          <% circle_order_for(attempts).each do |lbl| %>
            <% color, bg = circle_colors[lbl] %>
            <% label_text = puzzle.send("label_#{lbl}") %>
            <% cnt = game_session.send("attempts_#{lbl}") %>
            <% solved = game_session.send("solved_#{lbl}?") %>
            <% wrong = [cnt - (solved ? 1 : 0), 0].max %>
            <div style="display:flex;align-items:center;gap:9px;border:1.5px solid <%= color %>;border-radius:12px;padding:9px 12px;background:<%= bg %>;">
              <span style="width:22px;height:22px;border-radius:50%;background:<%= color %>;color:white;font-weight:700;font-size:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;"><%= lbl.upcase %></span>
              <span style="flex:1;font-weight:600;font-size:13px;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;"><%= label_text %></span>
              <span style="font-size:12px;letter-spacing:2px;color:#aaa;"><%= "✗" * wrong %></span>
              <% if solved %><span style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:<%= color %>;color:white;font-size:10px;font-weight:700;">✓</span><% end %>
            </div>
          <% end %>
        </div>

        <% _share_text = build_share_string_for(game_session, puzzle, circle_order: circle_order_for(attempts)) %>
        <% _game_id    = game_id_for(puzzle) %>
        <button onclick="vennShare(<%= _share_text.to_json %>, <%= _game_id.to_json %>)" id="share-score-btn"
                style="width:100%;background:#1a1a2e;color:white;font-weight:700;font-size:14px;border:none;border-radius:12px;height:44px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
          Share score
        </button>
      </div>

      <% if puzzle.puzzle_type == "user" %>
        <div style="text-align:center;">
          <% if user_signed_in? %>
            <% user_rating = current_user.ratings.find_by(puzzle: puzzle) %>
            <p style="font-size:12px;color:#999;margin:0 0 6px;font-family:'Inter',system-ui,sans-serif;">
              <%= user_rating ? "Your rating" : "Rate this puzzle" %>
            </p>
            <div id="stars-container" data-current="<%= user_rating&.score || 0 %>">
              <% 5.times do |i| %>
                <button onclick="submitRating(<%= puzzle.id %>, <%= i+1 %>)"
                        onmouseover="hoverStars(<%= i+1 %>)"
                        onmouseout="resetStars()"
                        data-index="<%= i+1 %>"
                        style="font-size:30px;background:none;border:none;cursor:pointer;padding:0 1px;line-height:1;color:<%= user_rating && (i+1) <= user_rating.score ? '#F59E0B' : '#ddd' %>;">★</button>
              <% end %>
            </div>
            <p id="rating-label" style="font-size:11px;color:#aaa;margin:4px 0 0;font-family:'Inter',system-ui,sans-serif;min-height:16px;"><%= user_rating ? "#{user_rating.score}/5 — thanks!" : "" %></p>
          <% else %>
            <p style="font-size:12px;color:#aaa;margin:0;font-family:'Inter',system-ui,sans-serif;">
              <a href="/users/sign_in" style="color:#5B53D6;font-weight:600;text-decoration:none;">Sign in</a> to rate this puzzle
            </p>
          <% end %>
        </div>
      <% end %>

      <%# Mini stats %>
      <% if user_signed_in? %>
        <%
          _gs = current_user.game_sessions
            .joins(:puzzle)
            .where(puzzles: { puzzle_type: "daily" }, completed: true)
            .where("puzzles.scheduled_date <= ?", Date.today)
            .includes(:puzzle).to_a
          _dates = _gs.select { |s| s.created_at.to_date <= s.puzzle.scheduled_date + 1 }
                     .map { |s| s.puzzle.scheduled_date }.to_set
          _sd = _dates.include?(Date.today) ? Date.today : Date.today - 1
          _streak = 0; _d = _sd
          while _dates.include?(_d); _streak += 1; _d -= 1; end
          _misses = _gs.map { |s|
            (s.attempts_a - (s.gave_up_a? ? 0 : 1)) +
            (s.attempts_b - (s.gave_up_b? ? 0 : 1)) +
            (s.attempts_c - (s.gave_up_c? ? 0 : 1))
          }
          _avg = _misses.empty? ? nil : (_misses.sum.to_f / _misses.size).round(1)
        %>
        <div style="display:flex;align-items:center;gap:0;background:#f7f6fe;border-radius:12px;padding:10px 14px;font-family:'Inter',system-ui,sans-serif;">
          <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
            <% if _streak > 0 %><span style="font-size:15px;line-height:1;margin-right:2px;">🔥</span><% end %>
            <span style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;"><%= _streak %></span>
            <span style="font-size:11px;color:#aaa;font-weight:500;">day streak</span>
          </div>
          <div style="width:1px;height:22px;background:#e0ddf7;margin:0 12px;flex-shrink:0;"></div>
          <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
            <span style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;"><%= _avg || '—' %></span>
            <span style="font-size:11px;color:#aaa;font-weight:500;">avg misses</span>
          </div>
          <a href="/my/stats" style="font-size:11px;font-weight:700;color:#5B53D6;text-decoration:none;flex-shrink:0;margin-left:8px;">All stats →</a>
        </div>
      <% else %>
        <div id="guest-stats-block" style="display:none;background:#f7f6fe;border-radius:12px;padding:10px 14px;font-family:'Inter',system-ui,sans-serif;">
          <div style="display:flex;align-items:center;gap:0;">
            <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
              <span id="guest-streak-fire" style="font-size:15px;line-height:1;margin-right:2px;display:none;">🔥</span>
              <span id="guest-streak-num" style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;">0</span>
              <span style="font-size:11px;color:#aaa;font-weight:500;">day streak</span>
            </div>
            <div style="width:1px;height:22px;background:#e0ddf7;margin:0 12px;flex-shrink:0;"></div>
            <div style="display:flex;align-items:baseline;gap:4px;flex:1;">
              <span id="guest-avg-num" style="font-size:22px;font-weight:800;color:#1a1a2e;line-height:1;">—</span>
              <span style="font-size:11px;color:#aaa;font-weight:500;">avg misses</span>
            </div>
          </div>
        </div>
      <% end %>

      <%# Other CTAs %>
      <div style="display:flex;flex-direction:column;gap:8px;">
<button onclick="showDiagramPanel()" style="width:100%;background:transparent;border:1.5px solid rgba(0,0,0,0.15);color:#1a1a2e;font-weight:600;font-size:13px;border-radius:12px;height:40px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;touch-action:manipulation;">
  View completed puzzle
</button>
        <div style="display:flex;gap:8px;">
          <a href="/puzzles/new"
             style="flex:1;display:flex;align-items:center;justify-content:center;background:transparent;border:1.5px solid #E8631A;color:#E8631A;font-weight:700;font-size:13px;border-radius:12px;height:40px;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">
            + Create
          </a>
          <div style="flex:1;position:relative;">
            <button onclick="togglePlayMoreMenu(event)"
                    style="width:100%;background:transparent;border:1.5px solid #5B53D6;color:#5B53D6;font-weight:700;font-size:13px;border-radius:12px;height:40px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
              Play more ▾
            </button>
            <div id="play-more-menu" style="display:none;position:absolute;bottom:calc(100% + 6px);left:0;right:0;background:white;border:1px solid #eee;border-radius:12px;box-shadow:0 4px 16px rgba(0,0,0,0.1);overflow:hidden;z-index:100;">
              <a href="/archive" style="display:block;padding:12px 16px;font-size:13px;font-weight:600;color:#1a1a2e;text-decoration:none;font-family:'Inter',system-ui,sans-serif;border-bottom:1px solid #f0f0f0;">Daily archive</a>
              <a href="/puzzles" style="display:block;padding:12px 16px;font-size:13px;font-weight:600;color:#1a1a2e;text-decoration:none;font-family:'Inter',system-ui,sans-serif;">Community created</a>
            </div>
          </div>
        </div>
      </div>

      <% unless user_signed_in? %>
        <div style="text-align:center;padding-top:4px;">
          <p style="font-size:12px;color:#aaa;margin:0 0 6px;font-family:'Inter',system-ui,sans-serif;">Sign up to sync your stats across devices and create puzzles</p>
          <a href="/users/sign_up" style="font-size:12px;font-weight:700;color:#5B53D6;text-decoration:none;">Create a free account &rarr;</a>
        </div>
      <% end %>
    </div>

    <% content_for :body_overlays do %>
      <%# ── Diagram panel — rendered at body level to avoid iOS overflow:hidden clipping ── %>
      <div id="diagram-panel" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg,#ede8fb 0%,#fae3d5 100%);z-index:1000;flex-direction:column;gap:8px;padding:20px 20px max(20px,env(safe-area-inset-bottom)) 20px;box-sizing:border-box;">
        <div style="flex:1;min-height:0;overflow:hidden;">
          <svg viewBox="0 0 560 430" style="width:100%;height:100%;display:block;" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <filter id="pill-shadow-d" x="-20%" y="-40%" width="140%" height="180%">
                <feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.13"/>
              </filter>
            </defs>

            <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.5" stroke="#5B53D6" stroke-width="2"/>
            <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.5" stroke="#2BAB65" stroke-width="2"/>
            <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.5" stroke="#E8631A" stroke-width="2"/>

            <% a_pw = [puzzle.label_a.to_s.upcase.length * 8 + 24, 60].max %>
            <rect x="<%= 280 - a_pw/2 %>" y="8" width="<%= a_pw %>" height="28" rx="14" fill="#5B53D6"/>
            <text x="280" y="27" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= puzzle.label_a.to_s.upcase %></text>

            <% b_pw = [puzzle.label_b.to_s.upcase.length * 8 + 24, 60].max %>
            <rect x="<%= 185 - b_pw/2 %>" y="399" width="<%= b_pw %>" height="28" rx="14" fill="#2BAB65"/>
            <text x="185" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= puzzle.label_b.to_s.upcase %></text>

            <% c_pw = [puzzle.label_c.to_s.upcase.length * 8 + 24, 60].max %>
            <rect x="<%= 375 - c_pw/2 %>" y="399" width="<%= c_pw %>" height="28" rx="14" fill="#E8631A"/>
            <text x="375" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= puzzle.label_c.to_s.upcase %></text>

            <% { words_a: [280,59,76], words_b: [112,310,327], words_c: [448,310,327],
                 words_ab: [208,202,219], words_ac: [352,202,219],
                 words_bc: [280,323,340], words_abc: [280,235,252] }.each do |region, (cx,ry,ty)| %>
              <% word = puzzle.send(region)&.first %>
              <% if word %>
                <% pw = [word.length * 8 + 24, 60].max %>
                <rect x="<%= cx - pw/2 %>" y="<%= ry %>" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow-d)"/>
                <text x="<%= cx %>" y="<%= ty %>" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
              <% end %>
            <% end %>
          </svg>
        </div>
        <button onclick="showScorePanel()"
                style="flex-shrink:0;width:100%;background:transparent;border:1.5px solid rgba(0,0,0,0.15);color:#1a1a2e;font-weight:600;font-size:13px;border-radius:12px;height:40px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;touch-action:manipulation;">
          ← Back to results
        </button>
      </div>
    <% end %>

    <script>
      <%# vennShare and vennCopyFallback live in app/javascript/venn_share.js — do not re-define here %>

      function showDiagramPanel() {
        var dp = document.getElementById('diagram-panel');
        if (dp) dp.style.display = 'flex';
      }

      function showScorePanel() {
        var dp = document.getElementById('diagram-panel');
        if (dp) dp.style.display = 'none';
      }

      function togglePlayMoreMenu(event) {
        event.stopPropagation();
        var menu = document.getElementById('play-more-menu');
        var isOpen = menu.style.display !== 'none';
        menu.style.display = isOpen ? 'none' : 'block';
        if (!isOpen) {
          document.addEventListener('click', function closeMenu() {
            menu.style.display = 'none';
            document.removeEventListener('click', closeMenu);
          });
        }
      }

      function hoverStars(n) {
        document.querySelectorAll('#stars-container button[data-index]').forEach(function(btn) {
          btn.style.color = parseInt(btn.dataset.index) <= n ? '#FBBF24' : '#ddd';
        });
      }

      function resetStars() {
        var container = document.getElementById('stars-container');
        if (!container) return;
        var current = parseInt(container.dataset.current || 0);
        document.querySelectorAll('#stars-container button[data-index]').forEach(function(btn) {
          btn.style.color = parseInt(btn.dataset.index) <= current ? '#F59E0B' : '#ddd';
        });
      }

      <% unless user_signed_in? %>
      (function() {
        var isDaily = <%= (puzzle.puzzle_type == 'daily').to_json %>;
        var puzzleDate = <%= puzzle.scheduled_date&.to_s.to_json %>;
        var misses = <%= total_wrong %>;
        try {
          var saved = JSON.parse(localStorage.getItem('venndle_daily_stats') || '{}');
          function ds(d) {
            return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
          }
          var now = new Date();
          var today = ds(now);
          if (isDaily && puzzleDate && !saved[puzzleDate]) {
            saved[puzzleDate] = { misses: misses, playedAt: today };
            localStorage.setItem('venndle_daily_stats', JSON.stringify(saved));
          }
          if (Object.keys(saved).length === 0) return;
          var yesterday = ds(new Date(now - 86400000));
          // Only count entries played on the puzzle's date or the next day
          function validForStreak(puzzleDate, entry) {
            var pa = entry.playedAt;
            if (!pa) return true; // legacy entries without playedAt: trust them
            var diff = (new Date(pa + 'T12:00:00') - new Date(puzzleDate + 'T12:00:00')) / 86400000;
            return diff >= 0 && diff <= 1;
          }
          var validDates = {};
          Object.keys(saved).forEach(function(date) {
            if (validForStreak(date, saved[date])) validDates[date] = true;
          });
          var start = validDates[today] ? today : (validDates[yesterday] ? yesterday : null);
          var streak = 0;
          if (start) {
            var d = new Date(start + 'T12:00:00');
            while (validDates[ds(d)]) { streak++; d.setDate(d.getDate() - 1); }
          }
          var vals = Object.values(saved).map(function(v) { return v.misses; });
          var avg = vals.length ? Math.round(vals.reduce(function(a,b){return a+b;},0) / vals.length * 10) / 10 : null;
          document.getElementById('guest-streak-num').textContent = streak;
          if (streak > 0) document.getElementById('guest-streak-fire').style.display = '';
          document.getElementById('guest-avg-num').textContent = avg !== null ? avg : '—';
          document.getElementById('guest-stats-block').style.display = '';
        } catch(e) {}
      })();
      <% end %>

      function submitRating(puzzleId, score) {
        var csrf = document.querySelector('meta[name="csrf-token"]').content;
        fetch('/puzzles/' + puzzleId + '/rating', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
          body: JSON.stringify({ score: score })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            var container = document.getElementById('stars-container');
            container.dataset.current = score;
            document.querySelectorAll('#stars-container button[data-index]').forEach(function(btn) {
              btn.style.color = parseInt(btn.dataset.index) <= score ? '#F59E0B' : '#ddd';
            });
            var label = document.getElementById('rating-label');
            if (label) label.textContent = score + '/5 — thanks!';
          }
        });
      }
    </script>

  <% elsif game_session %>
    <%# ===== ACTIVE GAME STATE — zero scroll, fits viewport ===== %>

    <div style="height:100%;display:flex;flex-direction:column;gap:8px;">

      <%# SVG diagram — fills remaining space, scales to fit; sits on gradient directly %>
      <div style="flex:1;min-height:0;overflow:hidden;">
        <svg viewBox="0 0 560 430" style="width:100%;height:100%;display:block;" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="pill-shadow" x="-20%" y="-40%" width="140%" height="180%">
              <feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.13"/>
            </filter>
          </defs>

          <circle cx="280" cy="150" r="125" fill="#C8C4F2" fill-opacity="0.5" stroke="#5B53D6" stroke-width="2"/>
          <circle cx="185" cy="288" r="125" fill="#B8E4C8" fill-opacity="0.5" stroke="#2BAB65" stroke-width="2"/>
          <circle cx="375" cy="288" r="125" fill="#F5C4A0" fill-opacity="0.5" stroke="#E8631A" stroke-width="2"/>

          <%# A label pill — shows "A" in circle colour until solved, then real label %>
          <% a_solved = game_session.solved_a? %>
          <% a_display = a_solved ? puzzle.label_a.to_s.upcase : "A" %>
          <% a_pw = [a_display.length * 8 + 24, 60].max %>
          <g data-label-pill="a" data-cx="280" data-solved-color="#5B53D6">
            <rect x="<%= 280 - a_pw/2 %>" y="8" width="<%= a_pw %>" height="28" rx="14" fill="#5B53D6"/>
            <text x="280" y="27" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= a_display %></text>
          </g>

          <%# B label pill — shows "B" in circle colour until solved, then real label %>
          <% b_solved = game_session.solved_b? %>
          <% b_display = b_solved ? puzzle.label_b.to_s.upcase : "B" %>
          <% b_pw = [b_display.length * 8 + 24, 60].max %>
          <g data-label-pill="b" data-cx="185" data-solved-color="#2BAB65">
            <rect x="<%= 185 - b_pw/2 %>" y="399" width="<%= b_pw %>" height="28" rx="14" fill="#2BAB65"/>
            <text x="185" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= b_display %></text>
          </g>

          <%# C label pill — shows "C" in circle colour until solved, then real label %>
          <% c_solved = game_session.solved_c? %>
          <% c_display = c_solved ? puzzle.label_c.to_s.upcase : "C" %>
          <% c_pw = [c_display.length * 8 + 24, 60].max %>
          <g data-label-pill="c" data-cx="375" data-solved-color="#E8631A">
            <rect x="<%= 375 - c_pw/2 %>" y="399" width="<%= c_pw %>" height="28" rx="14" fill="#E8631A"/>
            <text x="375" y="418" text-anchor="middle" font-size="12" font-weight="700" font-family="system-ui,sans-serif" fill="white" letter-spacing="0.05em"><%= c_display %></text>
          </g>

          <%# Word pills %>
          <% { words_a: [280,59,76], words_b: [112,310,327], words_c: [448,310,327],
               words_ab: [208,202,219], words_ac: [352,202,219],
               words_bc: [280,323,340], words_abc: [280,235,252] }.each do |region, (cx,ry,ty)| %>
            <% word = puzzle.send(region)&.first %>
            <% if word %>
              <% pw = [word.length * 8 + 24, 60].max %>
              <rect x="<%= cx - pw/2 %>" y="<%= ry %>" width="<%= pw %>" height="26" rx="13" fill="#ffffff" filter="url(#pill-shadow)"/>
              <text x="<%= cx %>" y="<%= ty %>" text-anchor="middle" font-size="13" font-weight="500" font-family="system-ui,sans-serif" fill="#1a1a2e"><%= word %></text>
            <% end %>
          <% end %>
        </svg>
      </div>

      <%# Guess cards — 3 in a row on desktop, stacked on mobile %>
      <div class="guess-area">
        <% [
          ["a", "#5B53D6", "#EDEAFC", "#9B94E8"],
          ["b", "#2BAB65", "#E5F5EC", "#72C894"],
          ["c", "#E8631A", "#FDF0E9", "#F0956A"]
        ].each do |lbl, color, bg, placeholder_color| %>
          <% solved = game_session.send("solved_#{lbl}?") %>
          <% label_text = puzzle.send("label_#{lbl}") %>
          <% lbl_attempts = attempts.select { |a| a.label == lbl } %>
          <% last_correct_attempt = lbl_attempts.select(&:correct?).last %>

          <div id="guess-row-<%= lbl %>" class="guess-row"
               data-label="<%= lbl %>" data-solved="<%= solved %>"
               style="border:1.5px solid <%= color %>;border-radius:12px;padding:8px 10px;background:<%= bg %>;display:flex;flex-direction:column;gap:4px;min-width:0;">

            <div class="guess-row-main" style="display:flex;align-items:center;gap:8px;">
              <%# Letter badge %>
              <span style="width:24px;height:24px;border-radius:50%;background:<%= color %>;color:white;font-weight:700;font-size:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;">
                <%= lbl.upcase %>
              </span>

              <% if solved %>
                <span style="flex:1;font-weight:600;font-size:13px;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= label_text %></span>
                <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:#16a34a;color:white;font-size:10px;font-weight:700;flex-shrink:0;">✓</span>
              <% else %>
                <div class="guess-input-wrap" style="flex:1;display:flex;align-items:center;min-width:0;">
                  <span class="hint-prefix" style="font-size:13px;font-weight:700;color:#bbb;letter-spacing:1px;white-space:nowrap;font-family:'Inter',system-ui,sans-serif;line-height:1;flex-shrink:0;"></span>
                  <input type="text" name="guess"
                         placeholder="Category <%= lbl.upcase %>..."
                         autocomplete="off" autocorrect="off" autocapitalize="none" spellcheck="false"
                         style="flex:1;min-width:40px;border:none;background:transparent;font-size:13px;font-weight:500;color:#1a1a2e;outline:none;font-family:'Inter',system-ui,sans-serif;"
                         data-placeholder-color="<%= placeholder_color %>" />
                </div>
                <button class="submit-btn" data-label="<%= lbl %>"
                        style="flex-shrink:0;background:<%= color %>;color:white;font-weight:700;font-size:13px;border:none;border-radius:999px;height:26px;padding:0 12px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;line-height:1;">
                  &#8594;
                </button>
              <% end %>
            </div>

            <%# Attempt marks — second line %>
            <span id="marks-<%= lbl %>" style="display:flex;align-items:center;gap:3px;padding-left:32px;min-height:20px;">
              <% lbl_attempts.each do |attempt| %>
                <% if attempt.correct? %>
                  <span style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border-radius:50%;background:<%= color %>;color:white;font-size:8px;font-weight:700;">✓</span>
                <% else %>
                  <span style="font-size:18px;color:#ef4444;font-weight:900;line-height:1;">✗</span>
                <% end %>
              <% end %>
            </span>
            <% if solved && last_correct_attempt && last_correct_attempt.guess.to_s.downcase.strip != label_text.to_s.downcase.strip %>
              <span id="you-said-<%= lbl %>" style="font-size:11px;color:#999;padding-left:32px;font-style:italic;font-family:'Inter',system-ui,sans-serif;">you said: <%= last_correct_attempt.guess %></span>
            <% end %>

            <%# Hint controls — only for unsolved rows %>
            <% unless solved %>
              <div class="hint-ctrl" data-label="<%= lbl %>" style="padding-left:32px;display:flex;flex-direction:column;gap:2px;">
                <div style="display:flex;gap:8px;align-items:center;">
                  <button class="hint-btn" data-label="<%= lbl %>"
                          style="font-size:11px;color:#999;background:none;border:none;cursor:pointer;padding:0;font-family:'Inter',system-ui,sans-serif;text-decoration:underline;text-underline-offset:2px;">
                    Reveal letter
                  </button>
                  <span style="color:#ddd;font-size:10px;">|</span>
                  <button class="give-up-btn" data-label="<%= lbl %>"
                          style="font-size:11px;color:#e53e3e;background:none;border:none;cursor:pointer;padding:0;font-family:'Inter',system-ui,sans-serif;text-decoration:underline;text-underline-offset:2px;">
                    Give up
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <script>
      (function() {
        const puzzleId = "<%= puzzle.id %>";
        const gameId   = "<%= game_id_for(puzzle) %>";
        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
        const boardWords = new Set(<%= (puzzle.all_words || []).map(&:to_s).to_json.html_safe %>);

        // Placeholder colours via injected style since inline ::placeholder doesn't work
        document.querySelectorAll('.guess-row input[name="guess"]').forEach(function(input) {
          const color = input.dataset.placeholderColor;
          if (color) {
            const s = document.createElement('style');
            s.textContent = '#guess-row-' + input.closest('.guess-row').dataset.label + ' input::placeholder { color:' + color + '; opacity:1; }';
            document.head.appendChild(s);
          }
        });

        function getCircleColor(label) {
          return { a: '#5B53D6', b: '#2BAB65', c: '#E8631A' }[label] || '#1a1a2e';
        }

        function showRowError(row, msg) {
          let errEl = row.querySelector('.guess-error');
          if (!errEl) {
            errEl = document.createElement('span');
            errEl.className = 'guess-error';
            errEl.style.cssText = 'font-size:12px;font-weight:600;color:#e53e3e;padding-left:32px;display:block;';
            row.appendChild(errEl);
          }
          errEl.textContent = msg;
          setTimeout(function() { if (errEl.parentNode) errEl.textContent = ''; }, 4000);
        }

        function showRowDuplicate(row, msg) {
          let el = row.querySelector('.guess-duplicate');
          if (!el) {
            el = document.createElement('span');
            el.className = 'guess-duplicate';
            el.style.cssText = 'font-size:11px;color:#888;padding-left:32px;display:block;font-style:italic;';
            row.appendChild(el);
          }
          el.textContent = msg;
          setTimeout(function() { if (el.parentNode) el.textContent = ''; }, 3000);
        }

        async function submitGuess(label, btn) {
          const row = document.getElementById('guess-row-' + label);
          const input = row.querySelector('input[name="guess"]');
          const hintPfx = row.querySelector('.hint-prefix');
          const prefix = hintPfx ? hintPfx.textContent : '';
          if (!input || (!input.value.trim() && !prefix)) return;

          const guess = prefix + input.value.trim();

          btn.disabled = true;
          btn.innerHTML = '<span class="submit-btn-loading" style="display:inline-block;">↻</span>';

          try {
            const resp = await fetch('/puzzles/' + puzzleId + '/guess', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
              body: JSON.stringify({ label: label, guess: guess })
            });

            let data;
            try {
              data = await resp.json();
            } catch(parseErr) {
              console.error('Server returned non-JSON (status ' + resp.status + ')');
              showRowError(row, 'Server error — check that GEMINI_API_KEY is set');
              btn.disabled = false;
              btn.innerHTML = '&#8594;';
              return;
            }

            if (!resp.ok || data.error) {
              console.error('Guess error:', data.error || resp.status);
              showRowError(row, data.error || 'Something went wrong');
              btn.disabled = false;
              btn.innerHTML = '&#8594;';
              return;
            }

            if (data.duplicate) {
              showRowDuplicate(row, 'You already tried that');
              btn.disabled = false;
              btn.innerHTML = '&#8594;';
              input.value = '';
              return;
            }

            if (data.board_word) {
              row.style.transition = 'border-color 0.15s';
              row.style.borderColor = '#e53e3e';
              setTimeout(function() { row.style.borderColor = ''; setTimeout(function() { row.style.transition = ''; }, 150); }, 600);
              showRowError(row, "Can't submit board words");
              btn.disabled = false;
              btn.innerHTML = '&#8594;';
              return;
            }

            // Append attempt mark
            const marksEl = document.getElementById('marks-' + label);
            if (data.correct) {
              const m = document.createElement('span');
              m.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border-radius:50%;background:' + getCircleColor(label) + ';color:white;font-size:8px;font-weight:700;';
              m.textContent = '✓';
              marksEl.appendChild(m);
            } else {
              const m = document.createElement('span');
              m.style.cssText = 'font-size:18px;color:#ef4444;font-weight:900;line-height:1;';
              m.textContent = '✗';
              marksEl.appendChild(m);
              // Show tip after 2nd wrong guess on this circle
              var wrongCount = Array.from(marksEl.children).filter(function(s) { return s.textContent === '✗'; }).length;
              if (wrongCount >= 2) venndleShowGuessTip();
              // Brief red-border flash on the row to signal incorrect
              row.style.transition = 'border-color 0.15s';
              row.style.borderColor = '#e53e3e';
              setTimeout(function() { row.style.borderColor = ''; setTimeout(function() { row.style.transition = ''; }, 150); }, 500);
            }

            input.value = '';

            if (data.solved[label]) {
              row.dataset.solved = 'true';
              const officialLabel = data.official_label;
              const mainRow = row.querySelector('.guess-row-main');
              const inputWrap = mainRow.querySelector('.guess-input-wrap') || mainRow.querySelector('input[name="guess"]');
              if (inputWrap) {
                const labelSpan = document.createElement('span');
                labelSpan.style.cssText = "flex:1;font-weight:600;font-size:13px;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;";
                labelSpan.textContent = officialLabel;
                inputWrap.replaceWith(labelSpan);
              }
              btn.remove();
              const check = document.createElement('span');
              check.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:#16a34a;color:white;font-size:10px;font-weight:700;flex-shrink:0;';
              check.textContent = '✓';
              mainRow.appendChild(check);
              updateSvgPill(label, officialLabel, getCircleColor(label));
              if (guess.toLowerCase().trim() !== officialLabel.toLowerCase().trim()) {
                const youSaid = document.createElement('span');
                youSaid.style.cssText = "font-size:11px;color:#999;padding-left:32px;font-style:italic;font-family:'Inter',system-ui,sans-serif;";
                youSaid.textContent = 'you said: ' + guess;
                row.appendChild(youSaid);
              }
            } else {
              btn.disabled = false;
              btn.innerHTML = '&#8594;';
            }

            if (data.completed) {
              try { gtag('event', 'game_complete', { 'game_id': gameId }); } catch(e) {}
              const wrongMarks = ['a','b','c'].reduce(function(n, lbl) {
                const el = document.getElementById('marks-' + lbl);
                return n + (el ? Array.from(el.children).filter(function(s){ return s.textContent === '✗'; }).length : 0);
              }, 0);
              if (wrongMarks === 0 && typeof confetti === 'function') {
                const opts = { particleCount: 120, spread: 70, startVelocity: 60, decay: 0.92, ticks: 200,
                  colors: ['#5B53D6','#2BAB65','#E8631A','#ffffff','#ffd700'] };
                confetti(Object.assign({}, opts, { angle: 60,  origin: { x: 0, y: 1 } }));
                confetti(Object.assign({}, opts, { angle: 120, origin: { x: 1, y: 1 } }));
                setTimeout(function() { window.location.reload(); }, 2600);
              } else {
                window.location.reload();
              }
            }
          } catch(err) {
            console.error('Guess fetch failed:', err);
            showRowError(row, 'Network error — please try again');
            btn.disabled = false;
            btn.innerHTML = '&#8594;';
          }
        }

        function updateSvgPill(label, text, color) {
          const svg = document.querySelector('#venn-puzzle svg');
          if (!svg) return;
          const g = svg.querySelector('[data-label-pill="' + label + '"]');
          if (!g) return;
          const rect = g.querySelector('rect');
          const textEl = g.querySelector('text');
          if (!rect || !textEl) return;
          const display = text.toUpperCase();
          const pw = Math.max(display.length * 8 + 24, 60);
          const cx = parseFloat(g.dataset.cx);
          rect.setAttribute('fill', color);
          rect.setAttribute('width', pw);
          rect.setAttribute('x', cx - pw / 2);
          textEl.textContent = display;
        }

        document.querySelectorAll('.submit-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { submitGuess(btn.dataset.label, btn); });
        });

        document.querySelectorAll('.guess-row input[name="guess"]').forEach(function(input) {
          input.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
              e.preventDefault();
              const btn = input.closest('.guess-row').querySelector('.submit-btn');
              if (btn && !btn.disabled) submitGuess(btn.dataset.label, btn);
            }
          });
        });

        // ── Hint state (tracks revealed letters per label, client-side only) ──
        const hintState = { a: { revealed: [], totalLength: null }, b: { revealed: [], totalLength: null }, c: { revealed: [], totalLength: null } };

        async function fetchHint(label) {
          const row = document.getElementById('guess-row-' + label);
          if (row.dataset.solved === 'true') return;
          const state = hintState[label];
          const btn = row.querySelector('.hint-btn');

          if (btn && btn.disabled) return;
          if (btn) btn.disabled = true;

          try {
            const resp = await fetch('/puzzles/' + puzzleId + '/hint', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
              body: JSON.stringify({ label: label, revealed_count: state.revealed.length })
            });
            const data = await resp.json();

            if (data.done) {
              if (btn) { btn.disabled = true; btn.style.color = '#bbb'; btn.style.textDecoration = 'none'; btn.textContent = 'All revealed'; }
              return;
            }

            try { gtag('event', 'use_hint', { 'answer_level': label.toUpperCase(), 'game_id': gameId }); } catch(e) {}
            state.revealed.push(data.letter.toUpperCase());
            state.totalLength = data.total_length;

            const hintPrefix = row.querySelector('.hint-prefix');
            if (hintPrefix) hintPrefix.textContent = state.revealed.join('');
            const input = row.querySelector('input[name="guess"]');
            if (input) {
              input.placeholder = state.revealed.length < data.total_length ? '...' : '';
              input.focus();
            }

            if (state.revealed.length >= data.total_length) {
              if (btn) { btn.disabled = true; btn.style.color = '#bbb'; btn.style.textDecoration = 'none'; btn.textContent = 'All revealed'; }
            } else {
              if (btn) btn.disabled = false;
            }
          } catch(err) {
            console.error('Hint fetch failed:', err);
            if (btn) btn.disabled = false;
          }
        }

        async function giveUp(label) {
          if (!confirm('Give up on circle ' + label.toUpperCase() + '? This will reveal the answer.')) return;

          const row = document.getElementById('guess-row-' + label);
          const btn = row.querySelector('.give-up-btn');
          if (btn) btn.disabled = true;

          try {
            const resp = await fetch('/puzzles/' + puzzleId + '/give_up', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
              body: JSON.stringify({ label: label })
            });
            const data = await resp.json();

            if (!resp.ok || data.already_solved) { if (btn) btn.disabled = false; return; }

            try { gtag('event', 'game_give_up', { 'answer_level': label.toUpperCase(), 'game_id': gameId }); } catch(e) {}
            const officialLabel = data.official_label;
            row.dataset.solved = 'true';

            const mainRow = row.querySelector('.guess-row-main');
            const inputEl = mainRow.querySelector('input[name="guess"]');
            if (inputEl) {
              const labelSpan = document.createElement('span');
              labelSpan.style.cssText = "flex:1;font-size:13px;color:#888;font-family:'Inter',system-ui,sans-serif;font-style:italic;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;";
              labelSpan.textContent = officialLabel;
              inputEl.replaceWith(labelSpan);
            }
            const submitBtn = mainRow.querySelector('.submit-btn');
            if (submitBtn) submitBtn.remove();

            const indicator = document.createElement('span');
            indicator.title = 'Gave up';
            indicator.style.cssText = 'display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%;background:#bbb;color:white;font-size:11px;flex-shrink:0;';
            indicator.textContent = '—';
            mainRow.appendChild(indicator);

            const hintCtrl = row.querySelector('.hint-ctrl');
            if (hintCtrl) hintCtrl.remove();

            updateSvgPill(label, officialLabel, getCircleColor(label));

            if (data.completed) { try { gtag('event', 'game_complete', { 'game_id': gameId }); } catch(e) {} window.location.reload(); }
          } catch(err) {
            console.error('Give up fetch failed:', err);
            if (btn) btn.disabled = false;
          }
        }
        document.querySelectorAll('.hint-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { fetchHint(btn.dataset.label); });
        });

        document.querySelectorAll('.give-up-btn').forEach(function(btn) {
          btn.addEventListener('click', function() { giveUp(btn.dataset.label); });
        });

        // Track this puzzle as a game seen (for tip suppression)
        try {
          var _pid = String(<%= puzzle.id %>);
          if (localStorage.getItem('venndleTipLastPuzzle') !== _pid) {
            localStorage.setItem('venndleTipLastPuzzle', _pid);
            localStorage.setItem('venndleTipGamesPlayed', parseInt(localStorage.getItem('venndleTipGamesPlayed') || '0') + 1);
          }
        } catch(e) {}
      })();

      function venndleShowGuessTip() {
        var gamesPlayed = parseInt(localStorage.getItem('venndleTipGamesPlayed') || '0');
        var suppressUntil = parseInt(localStorage.getItem('venndleTipSuppressUntil') || '0');
        if (gamesPlayed < suppressUntil) return;

        // Mark shown — suppress for the next 5 games
        try { localStorage.setItem('venndleTipSuppressUntil', gamesPlayed + 5); } catch(e) {}

        var existing = document.getElementById('venndle-guess-tip-popup');
        if (existing) return;

        var popup = document.createElement('div');
        popup.id = 'venndle-guess-tip-popup';
        popup.style.cssText = [
          'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:2000;',
          'background:#fffbeb;border:1px solid #fde68a;border-radius:14px;',
          'padding:14px 18px;display:flex;align-items:flex-start;gap:8px;',
          'max-width:280px;width:calc(100% - 48px);box-sizing:border-box;',
          'box-shadow:0 8px 24px rgba(0,0,0,0.14);',
          "font-family:'Inter',system-ui,sans-serif;font-size:13px;color:#6d5a2c;line-height:1.55;",
          'opacity:1;transition:opacity 0.4s ease;pointer-events:none;'
        ].join('');
        popup.innerHTML = '<span style="flex-shrink:0;font-size:16px;">💡</span>' +
          "<span>Don't forget! Your answer needs to fit all the words in this circle 😊</span>";
        document.body.appendChild(popup);

        setTimeout(function() {
          popup.style.opacity = '0';
          setTimeout(function() { if (popup.parentNode) popup.remove(); }, 400);
        }, 3000);
      }
    </script>

  <% end %>

</div>
