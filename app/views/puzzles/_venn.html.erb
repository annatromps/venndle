<%# Venn diagram + guess cards shared by daily and show views %>
<% game_session ||= nil %>
<% attempts ||= [] %>

<div id="venn-puzzle" data-puzzle-id="<%= puzzle.id %>">

  <%# SVG Venn Diagram %>
  <div class="flex justify-center mb-8">
    <svg viewBox="0 0 560 340" width="560" height="340" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <%# Clip paths for each exclusive region %>
        <clipPath id="clip-a">
          <circle cx="280" cy="105" r="115"/>
        </clipPath>
        <clipPath id="clip-b">
          <circle cx="185" cy="248" r="115"/>
        </clipPath>
        <clipPath id="clip-c">
          <circle cx="375" cy="248" r="115"/>
        </clipPath>
      </defs>

      <%# Circle A - top centre - blue %>
      <circle cx="280" cy="105" r="115" fill="#B5D4F4" fill-opacity="0.55" stroke="#7fb3e8" stroke-width="1.5"/>
      <%# Circle B - bottom left - green %>
      <circle cx="185" cy="248" r="115" fill="#C0DD97" fill-opacity="0.55" stroke="#8bc34a" stroke-width="1.5"/>
      <%# Circle C - bottom right - amber %>
      <circle cx="375" cy="248" r="115" fill="#FAC775" fill-opacity="0.55" stroke="#f59e0b" stroke-width="1.5"/>

      <%# Region labels (circle letters, outside) %>
      <text x="280" y="22" text-anchor="middle" font-size="13" font-weight="600" fill="#4a90d9" font-family="sans-serif">A</text>
      <text x="88" y="310" text-anchor="middle" font-size="13" font-weight="600" fill="#6aaa1f" font-family="sans-serif">B</text>
      <text x="472" y="310" text-anchor="middle" font-size="13" font-weight="600" fill="#d97706" font-family="sans-serif">C</text>

      <%# Words in each region as pills %>
      <%# Region A only (top, not overlapping B or C) %>
      <% (puzzle.words_a || []).each_with_index do |word, i| %>
        <% x = 280; y = 58 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.75"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-family="sans-serif" fill="#1e3a5f"><%= word %></text>
      <% end %>

      <%# Region B only (bottom-left, not overlapping A or C) %>
      <% (puzzle.words_b || []).each_with_index do |word, i| %>
        <% x = 135; y = 278 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.75"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-family="sans-serif" fill="#2d5a0f"><%= word %></text>
      <% end %>

      <%# Region C only (bottom-right, not overlapping A or B) %>
      <% (puzzle.words_c || []).each_with_index do |word, i| %>
        <% x = 425; y = 278 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.75"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-family="sans-serif" fill="#78350f"><%= word %></text>
      <% end %>

      <%# AB overlap %>
      <% (puzzle.words_ab || []).each_with_index do |word, i| %>
        <% x = 218; y = 185 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.8"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-family="sans-serif" fill="#333"><%= word %></text>
      <% end %>

      <%# AC overlap %>
      <% (puzzle.words_ac || []).each_with_index do |word, i| %>
        <% x = 342; y = 185 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.8"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-family="sans-serif" fill="#333"><%= word %></text>
      <% end %>

      <%# BC overlap %>
      <% (puzzle.words_bc || []).each_with_index do |word, i| %>
        <% x = 280; y = 268 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.8"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-family="sans-serif" fill="#333"><%= word %></text>
      <% end %>

      <%# ABC centre %>
      <% (puzzle.words_abc || []).each_with_index do |word, i| %>
        <% x = 280; y = 220 + i * 18 %>
        <rect x="<%= x - word.length * 3.5 - 4 %>" y="<%= y - 10 %>" width="<%= word.length * 7 + 8 %>" height="16" rx="8" fill="white" fill-opacity="0.9"/>
        <text x="<%= x %>" y="<%= y + 2 %>" text-anchor="middle" font-size="10" font-weight="600" font-family="sans-serif" fill="#333"><%= word %></text>
      <% end %>
    </svg>
  </div>

  <% if user_signed_in? && game_session %>
    <%# Guess cards %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <% [["a", "#B5D4F4", "#1e3a5f"], ["b", "#C0DD97", "#2d5a0f"], ["c", "#FAC775", "#78350f"]].each do |label, bg, text_color| %>
        <% solved = game_session.send("solved_#{label}?") %>
        <% label_text = puzzle.send("label_#{label}") %>
        <% label_attempts = attempts.select { |a| a.label == label } %>
        <div id="card-<%= label %>" class="rounded-xl p-4 border-2 transition-all <%= solved ? 'border-green-400 bg-green-50' : 'border-gray-200 bg-white' %>">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-6 h-6 rounded-full text-xs font-bold flex items-center justify-center" style="background:<%= bg %>; color:<%= text_color %>"><%= label.upcase %></span>
            <% if solved %>
              <span class="text-sm font-semibold text-green-700"><%= label_text %> ✅</span>
            <% else %>
              <span class="text-sm font-medium text-gray-500">Circle <%= label.upcase %></span>
            <% end %>
          </div>

          <%# Attempt history %>
          <div class="flex flex-wrap gap-1 mb-3 min-h-6" id="attempts-<%= label %>">
            <% label_attempts.each do |attempt| %>
              <span class="text-lg"><%= attempt.correct? ? "✅" : "❌" %></span>
            <% end %>
          </div>

          <% unless solved %>
            <form class="guess-form flex gap-2" data-label="<%= label %>">
              <input
                type="text"
                name="guess"
                placeholder="What connects them?"
                class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-300"
                autocomplete="off"
              />
              <button type="submit" class="text-sm bg-gray-900 text-white px-3 py-2 rounded-lg hover:bg-gray-700 transition-colors">
                Guess
              </button>
            </form>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Share section %>
    <div id="share-section" class="<%= game_session.completed? ? '' : 'hidden' %> bg-gray-50 rounded-xl p-6 text-center border border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Puzzle complete!</h3>
      <p id="share-string" class="font-mono text-sm text-gray-700 mb-4 whitespace-pre-wrap"><%= game_session.completed? ? build_share_string_for(game_session, puzzle) : "" %></p>
      <button onclick="copyShare()" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm hover:bg-gray-700 transition-colors">
        Copy score
      </button>
    </div>

    <script>
      (function() {
        const puzzleId = "<%= puzzle.id %>";
        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

        document.querySelectorAll('.guess-form').forEach(function(form) {
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            const label = form.dataset.label;
            const guess = form.querySelector('input[name="guess"]').value.trim();
            if (!guess) return;

            fetch('/puzzles/' + puzzleId + '/guess', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': csrfToken
              },
              body: JSON.stringify({ label: label, guess: guess })
            })
            .then(r => r.json())
            .then(function(data) {
              const attemptsEl = document.getElementById('attempts-' + label);
              const emoji = document.createElement('span');
              emoji.className = 'text-lg';
              emoji.textContent = data.correct ? '✅' : '❌';
              attemptsEl.appendChild(emoji);

              form.querySelector('input').value = '';

              if (data.solved[label]) {
                const card = document.getElementById('card-' + label);
                card.classList.remove('border-gray-200', 'bg-white');
                card.classList.add('border-green-400', 'bg-green-50');
                const headerDiv = card.querySelector('.flex.items-center');
                const labelSpan = headerDiv.querySelector('span:last-child');
                labelSpan.textContent = data['label_' + label] + ' ✅';
                labelSpan.className = 'text-sm font-semibold text-green-700';
                form.remove();
              }

              if (data.completed) {
                const shareSection = document.getElementById('share-section');
                shareSection.classList.remove('hidden');
                document.getElementById('share-string').textContent = data.share_string;
              }
            })
            .catch(function(err) {
              console.error('Guess failed:', err);
            });
          });
        });
      })();

      function copyShare() {
        const text = document.getElementById('share-string').textContent;
        navigator.clipboard.writeText(text).then(function() {
          const btn = event.target;
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.textContent = 'Copy score'; }, 2000);
        });
      }
    </script>

  <% else %>
    <div class="text-center py-8">
      <p class="text-gray-500 mb-4">Sign in to play this puzzle.</p>
      <a href="/users/sign_in" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm hover:bg-gray-700">Sign in</a>
    </div>
  <% end %>
</div>
