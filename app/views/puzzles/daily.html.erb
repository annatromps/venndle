<% content_for :og_title, "Venndle #{(@puzzle&.scheduled_date || Date.today).strftime("%-d %b")} — can you solve it?" if @puzzle %>
<% content_for :head do %><meta name="turbo-cache-control" content="no-store"><% end %>
<% if @puzzle %>
  <style>@media(max-width:600px){.daily-h1{font-size:18px !important;line-height:1.2 !important;}}</style>
  <div style="height:100%;display:flex;flex-direction:column;padding:8px 16px 4px;box-sizing:border-box;max-width:700px;margin:0 auto;width:100%;">

    <%# Header — compact, fixed height %>
    <div style="flex-shrink:0;margin-bottom:2px;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">
        <span style="display:inline-flex;align-items:center;background:#F59E0B;color:white;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:999px;font-family:'Inter',system-ui,sans-serif;flex-shrink:0;">Daily</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
        <h1 class="daily-h1" style="font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#1a1a2e;margin:0;line-height:1.15;min-width:0;">
          #<%= @daily_number %> &middot; <%= (@puzzle.scheduled_date || Date.today).strftime("%-d %b %Y") %><%= @puzzle.title.present? ? " — #{@puzzle.title}" : "" %>
        </h1>
        <% if admin_view? %>
          <form action="<%= puzzle_reset_session_path(@puzzle) %>" method="post" style="display:inline;margin:0;padding:0;flex-shrink:0;">
            <input type="hidden" name="_method" value="delete">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
            <button type="submit" style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;font-size:10px;font-weight:700;border-radius:6px;padding:2px 8px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;line-height:1.6;">Reset</button>
          </form>
        <% end %>
        <button onclick="document.getElementById('instructions-modal').style.display='flex'"
                style="flex-shrink:0;width:32px;height:32px;border-radius:50%;background:transparent;border:1.5px solid #ddd;color:#aaa;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:'Inter',system-ui,sans-serif;line-height:1;"
                title="How to play">i</button>
      </div>
    </div>

    <%# Venn content — fills remaining height %>
    <div style="flex:1;min-height:0;overflow:hidden;position:relative;">
      <%= render "venn", puzzle: @puzzle, game_session: @game_session, attempts: (@attempts || []) %>
    </div>

    <%# Tester feedback box %>
    <% if user_signed_in? && current_user.tester? %>
      <%
        existing_feedback = @puzzle.puzzle_feedbacks.find_by(user: current_user)
        feedback_submitted = flash[:notice]&.include?("Feedback")
      %>
      <div style="flex-shrink:0;margin-top:10px;padding:12px 14px;background:#fafafa;border:1.5px solid #ede9fe;border-radius:14px;font-family:'Inter',system-ui,sans-serif;">
        <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#9B94E8;margin:0 0 8px;">Tester feedback</p>

        <%# Accepted answers per circle %>
        <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:10px;">
          <% [["a", "#5B53D6"], ["b", "#2BAB65"], ["c", "#E8631A"]].each do |lbl, color| %>
            <% answers = @puzzle.send("accepted_answers_#{lbl}") %>
            <% label   = @puzzle.send("label_#{lbl}") %>
            <% if answers.present? %>
              <div style="display:flex;align-items:baseline;gap:6px;flex-wrap:wrap;">
                <span style="width:16px;height:16px;border-radius:50%;background:<%= color %>;color:white;font-weight:700;font-size:9px;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',system-ui,sans-serif;"><%= lbl.upcase %></span>
                <span style="font-size:11px;font-weight:700;color:#1a1a2e;"><%= label %></span>
                <span style="font-size:11px;color:#aaa;">also accepts:</span>
                <span style="font-size:11px;color:#555;"><%= answers.reject { |a| a.downcase == label.to_s.downcase }.join(", ") %></span>
              </div>
            <% end %>
          <% end %>
        </div>

        <% if feedback_submitted %>
          <p style="font-size:13px;color:#2BAB65;margin:0 0 6px;font-weight:600;">Saved!</p>
        <% end %>
        <%= form_with url: puzzle_feedback_path(@puzzle), method: :post, local: true do %>
          <textarea name="body" rows="3" placeholder="What do you think of this puzzle? Any issues with the words or labels?"
            style="width:100%;box-sizing:border-box;border:1.5px solid rgba(0,0,0,0.1);border-radius:10px;padding:8px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;resize:vertical;line-height:1.5;margin-bottom:6px;"><%= existing_feedback&.body %></textarea>
          <label style="display:block;font-size:11px;font-weight:600;color:#9B94E8;margin-bottom:4px;">Missing accepted answers (comma-separated)</label>
          <textarea name="missing_answers" rows="2" placeholder="e.g. synonym, alternate spelling"
            style="width:100%;box-sizing:border-box;border:1.5px solid #ede9fe;border-radius:10px;padding:8px 10px;font-size:13px;font-family:'Inter',system-ui,sans-serif;outline:none;color:#1a1a2e;resize:vertical;line-height:1.5;"><%= existing_feedback&.missing_answers %></textarea>
          <button type="submit"
            style="margin-top:6px;background:#5B53D6;color:white;font-weight:700;font-size:13px;border:none;border-radius:10px;padding:8px 18px;cursor:pointer;font-family:'Inter',system-ui,sans-serif;">
            <%= existing_feedback ? "Update feedback" : "Submit feedback" %>
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div style="height:100%;display:flex;align-items:center;justify-content:center;padding:16px;box-sizing:border-box;">
    <div style="background:white;border-radius:24px;box-shadow:0 4px 32px rgba(0,0,0,0.09);padding:48px 32px;text-align:center;max-width:380px;width:100%;">
      <div style="margin-bottom:20px;">
        <svg width="56" height="56" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="display:inline-block;">
          <circle cx="50" cy="38" r="28" fill="#C8C4F2" fill-opacity="0.7" stroke="#5B53D6" stroke-width="2"/>
          <circle cx="34" cy="65" r="28" fill="#B8E4C8" fill-opacity="0.7" stroke="#2BAB65" stroke-width="2"/>
          <circle cx="66" cy="65" r="28" fill="#F5C4A0" fill-opacity="0.7" stroke="#E8631A" stroke-width="2"/>
        </svg>
      </div>
      <h1 style="font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:#1a1a2e;margin:0 0 10px;">No puzzle today</h1>
      <p style="color:#999;font-size:14px;margin:0 0 24px;">Check back soon, or play a community puzzle.</p>
      <a href="/puzzles" style="display:inline-block;font-weight:700;font-size:14px;padding:14px 28px;border-radius:14px;background:#1a1a2e;color:white;text-decoration:none;">Browse puzzles</a>
    </div>
  </div>
<% end %>
