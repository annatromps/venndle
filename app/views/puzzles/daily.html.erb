<div style="min-height:100vh;padding:8px 16px 40px;">
  <% if @puzzle %>
    <div style="max-width:420px;margin:0 auto;">
      <%# White card %>
      <div style="background:white;border-radius:24px;box-shadow:0 4px 32px rgba(0,0,0,0.09);padding:28px 24px 24px;overflow:hidden;">

        <%# Card header %>
        <div style="margin-bottom:18px;">
          <div style="display:flex;align-items:center;gap:7px;margin-bottom:4px;">
            <span style="width:8px;height:8px;border-radius:50%;background:#F59E0B;display:inline-block;flex-shrink:0;"></span>
            <span style="font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#666;font-family:'Inter',system-ui,sans-serif;">
              <%= (@puzzle.scheduled_date || Date.today).strftime("%A %-d %B").upcase %>
            </span>
          </div>
          <h1 style="font-family:'Playfair Display',serif;font-size:42px;font-weight:700;color:#1a1a2e;margin:0;line-height:1.1;">
            Puzzle &numero;<%= @puzzle.id %>
          </h1>
        </div>

        <%= render "venn", puzzle: @puzzle, game_session: @game_session, attempts: (@attempts || []) %>

        <%# Footer %>
        <div style="margin-top:20px;padding-top:16px;border-top:1px solid #f0f0f0;text-align:center;">
          <span style="font-size:12px;color:#aaa;font-weight:400;">
            Made with care &middot;
            <a href="/puzzles" style="color:#aaa;text-decoration:none;">Puzzles</a>
            &middot;
            <% if user_signed_in? %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                    style: "font-size:12px;color:#aaa;background:transparent;border:none;cursor:pointer;padding:0;font-family:'Inter',system-ui,sans-serif;" %>
            <% else %>
              <a href="/users/sign_in" style="color:#aaa;text-decoration:none;">Sign in</a>
            <% end %>
          </span>
        </div>
      </div>
    </div>
  <% else %>
    <div style="max-width:420px;margin:0 auto;">
      <div style="background:white;border-radius:24px;box-shadow:0 4px 32px rgba(0,0,0,0.09);padding:48px 32px;text-align:center;">
        <div style="margin-bottom:20px;">
          <svg width="56" height="56" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="display:inline-block;">
            <circle cx="50" cy="38" r="28" fill="#C8C4F2" fill-opacity="0.7" stroke="#5B53D6" stroke-width="2"/>
            <circle cx="34" cy="65" r="28" fill="#B8E4C8" fill-opacity="0.7" stroke="#2BAB65" stroke-width="2"/>
            <circle cx="66" cy="65" r="28" fill="#F5C4A0" fill-opacity="0.7" stroke="#E8631A" stroke-width="2"/>
          </svg>
        </div>
        <h1 style="font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:#1a1a2e;margin:0 0 10px;">No puzzle today</h1>
        <p style="color:#999;font-size:14px;margin:0 0 24px;">Check back soon, or play a community puzzle.</p>
        <a href="/puzzles" style="display:inline-block;font-weight:700;font-size:14px;padding:14px 28px;border-radius:14px;background:#1a1a2e;color:white;text-decoration:none;">Browse puzzles</a>
      </div>
    </div>
  <% end %>
</div>
