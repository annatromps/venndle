<% if @puzzle %>
  <div class="mb-6 text-center">
    <h1 class="text-3xl font-bold text-gray-900 mb-1"><%= @puzzle.title %></h1>
    <p class="text-sm text-gray-400">Daily puzzle &middot; <%= @puzzle.scheduled_date&.strftime("%B %-d, %Y") || "Today" %></p>
  </div>
  <%= render "venn", puzzle: @puzzle, game_session: @game_session, attempts: @attempts %>
<% else %>
  <div class="text-center py-20">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">No daily puzzle today</h1>
    <p class="text-gray-500 mb-6">Check back soon, or explore community puzzles.</p>
    <a href="/puzzles" class="bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-gray-700">Browse puzzles</a>
  </div>
<% end %>
