<% content_for :title, "My Stats — Venndle" %>

<div style="height:100%;overflow-y:auto;padding:24px 20px 40px;box-sizing:border-box;">
  <div style="max-width:520px;margin:0 auto;">

    <h1 style="font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#1a1a2e;margin:0 0 4px;">My stats</h1>
    <p style="font-size:13px;color:#999;margin:0 0 28px;font-family:'Inter',system-ui,sans-serif;">Daily puzzles only</p>

    <% if @total_completed == 0 %>
      <div style="text-align:center;padding:48px 0;color:#aaa;font-family:'Inter',system-ui,sans-serif;">
        <div style="font-size:36px;margin-bottom:12px;">🧩</div>
        <p style="font-size:14px;margin:0;">Complete your first daily puzzle to see stats.</p>
        <a href="/" style="display:inline-block;margin-top:16px;background:#1a1a2e;color:white;font-weight:700;font-size:13px;text-decoration:none;border-radius:10px;padding:8px 20px;font-family:'Inter',system-ui,sans-serif;">Play today's puzzle</a>
      </div>

    <% else %>

      <%# ── Row 1: Streak cards ── %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">

        <%# Current streak %>
        <div style="background:white;border-radius:16px;padding:20px 20px 18px;border:1.5px solid rgba(0,0,0,0.07);">
          <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#aaa;font-family:'Inter',system-ui,sans-serif;margin-bottom:10px;">Current streak</div>
          <div style="display:flex;align-items:baseline;gap:6px;">
            <% if @current_streak > 0 %>
              <span style="font-size:36px;line-height:1;margin-right:2px;">🔥</span>
            <% end %>
            <span style="font-size:48px;font-weight:800;color:<%= @current_streak > 0 ? '#1a1a2e' : '#ccc' %>;font-family:'Inter',system-ui,sans-serif;line-height:1;">
              <%= @current_streak %>
            </span>
            <span style="font-size:14px;font-weight:600;color:#aaa;font-family:'Inter',system-ui,sans-serif;">
              <%= @current_streak == 1 ? 'day' : 'days' %>
            </span>
          </div>
          <div style="margin-top:8px;font-size:12px;color:#bbb;font-family:'Inter',system-ui,sans-serif;">
            <% if @current_streak == 0 %>
              Play today to start one
            <% elsif @current_streak == 1 %>
              Keep it going!
            <% else %>
              Don't break it
            <% end %>
          </div>
        </div>

        <%# Longest streak %>
        <div style="background:white;border-radius:16px;padding:20px 20px 18px;border:1.5px solid rgba(0,0,0,0.07);">
          <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#aaa;font-family:'Inter',system-ui,sans-serif;margin-bottom:10px;">Best streak</div>
          <div style="display:flex;align-items:baseline;gap:6px;">
            <span style="font-size:48px;font-weight:800;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;line-height:1;">
              <%= @longest_streak %>
            </span>
            <span style="font-size:14px;font-weight:600;color:#aaa;font-family:'Inter',system-ui,sans-serif;">
              <%= @longest_streak == 1 ? 'day' : 'days' %>
            </span>
          </div>
          <div style="margin-top:8px;font-size:12px;color:#bbb;font-family:'Inter',system-ui,sans-serif;">
            All time
          </div>
        </div>
      </div>

      <%# ── Row 2: Accuracy card ── %>
      <%
        avg   = @avg_misses
        best  = @best_misses
        color = if avg.nil? then '#aaa'
                elsif avg <= 1  then '#16a34a'
                elsif avg <= 3  then '#2BAB65'
                elsif avg <= 6  then '#F59E0B'
                else '#E8631A'
                end
        label = if avg.nil? then '—'
                elsif avg == 0.0 then 'Perfect'
                elsif avg <= 1.5 then 'Sharp'
                elsif avg <= 3.5 then 'Solid'
                elsif avg <= 6   then 'Getting there'
                else 'Room to improve'
                end
      %>
      <div style="background:white;border-radius:16px;padding:20px 20px 18px;border:1.5px solid rgba(0,0,0,0.07);margin-bottom:12px;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
          <div>
            <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#aaa;font-family:'Inter',system-ui,sans-serif;margin-bottom:10px;">Avg. wrong guesses</div>
            <div style="display:flex;align-items:baseline;gap:8px;">
              <span style="font-size:48px;font-weight:800;color:<%= color %>;font-family:'Inter',system-ui,sans-serif;line-height:1;">
                <%= avg || '—' %>
              </span>
              <span style="font-size:13px;font-weight:600;color:#bbb;font-family:'Inter',system-ui,sans-serif;">per puzzle</span>
            </div>
            <div style="margin-top:6px;font-size:12px;font-weight:600;color:<%= color %>;font-family:'Inter',system-ui,sans-serif;">
              <%= label %>
            </div>
          </div>
          <div style="text-align:right;flex-shrink:0;">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#aaa;font-family:'Inter',system-ui,sans-serif;margin-bottom:8px;">Lower is better</div>
            <% if best %>
              <div style="font-size:11px;color:#bbb;font-family:'Inter',system-ui,sans-serif;margin-bottom:2px;">Best game</div>
              <div style="font-size:22px;font-weight:800;color:#16a34a;font-family:'Inter',system-ui,sans-serif;"><%= best %></div>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Row 3: Score distribution ── %>
      <% max_count = @score_distribution.map(&:last).max.to_f %>
      <% max_count = 1.0 if max_count == 0 %>
      <div style="background:white;border-radius:16px;padding:20px 20px 18px;border:1.5px solid rgba(0,0,0,0.07);margin-bottom:12px;">
        <div style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#aaa;font-family:'Inter',system-ui,sans-serif;margin-bottom:14px;">Score distribution</div>
        <div style="display:flex;flex-direction:column;gap:6px;">
          <% @score_distribution.each do |label, count| %>
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="font-size:12px;font-weight:700;color:#555;font-family:'Inter',system-ui,sans-serif;width:22px;text-align:right;flex-shrink:0;"><%= label %></div>
              <div style="flex:1;position:relative;height:24px;">
                <% pct = count > 0 ? [(count / max_count * 100).round, 8].max : 4 %>
                <div style="width:<%= pct %>%;height:100%;background:<%= count > 0 ? '#1a1a2e' : '#e5e7eb' %>;border-radius:4px;display:flex;align-items:center;justify-content:flex-end;padding-right:<%= count > 0 ? '8px' : '0' %>;box-sizing:border-box;min-width:24px;">
                  <% if count > 0 %>
                    <span style="font-size:12px;font-weight:700;color:white;font-family:'Inter',system-ui,sans-serif;"><%= count %></span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div style="margin-top:10px;font-size:11px;color:#ccc;font-family:'Inter',system-ui,sans-serif;">Wrong guesses per puzzle — lower is better</div>
      </div>

      <%# ── Row 4: Totals ── %>
      <div style="background:white;border-radius:16px;padding:18px 20px;border:1.5px solid rgba(0,0,0,0.07);">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <div style="font-size:13px;font-weight:500;color:#555;font-family:'Inter',system-ui,sans-serif;">Daily puzzles completed</div>
          <div style="font-size:20px;font-weight:800;color:#1a1a2e;font-family:'Inter',system-ui,sans-serif;"><%= @total_completed %></div>
        </div>
      </div>

    <% end %>
  </div>
</div>
